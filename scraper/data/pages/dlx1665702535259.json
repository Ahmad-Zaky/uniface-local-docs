e1_d15145e1__entry__1\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 177px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\">\n<p class=\"p\">Function</p>\n</div></th><th aria-controls=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1\" aria-label=\"\n                        Description\n                     : activate to sort column ascending\" class=\"entry sorting\" colspan=\"1\" dir=\"ltr\" id=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 731px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\">\n<p class=\"p\">Description</p>\n</div></th></tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"unj1665702537632.html\" href=\"/de-DE/bundle/uniface_104/page/unj1665702537632.html\" title=\"Returns the value of the specified field.\">getValue()</a>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns the field's value.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qmn1665702537711.html\" href=\"/de-DE/bundle/uniface_104/page/qmn1665702537711.html\" title=\"Sets the value of the specified field.\">setValue()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets the field value.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"hwh1665702536527.html\" href=\"/de-DE/bundle/uniface_104/page/hwh1665702536527.html\" title=\"Returns the value of a property of this Uniface data object.\">getProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns the value of one of the field's properties.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"nkl1665702536608.html\" href=\"/de-DE/bundle/uniface_104/page/nkl1665702536608.html\" title=\"Sets the specified widget property to a given value.\">setProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets the value of one of the field's properties.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"pym1665702536682.html\" href=\"/de-DE/bundle/uniface_104/page/pym1665702536682.html\" title=\"Restores the initial value of the specified property.\">clearProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Restores the initial value of the specified property.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"med1665702536765.html\" href=\"/de-DE/bundle/uniface_104/page/med1665702536765.html\" title=\"Returns the properties of this Uniface data object.\">getProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns all of the field's properties as a JavaScript object.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qbz1665702536840.html\" href=\"/de-DE/bundle/uniface_104/page/qbz1665702536840.html\" title=\"Sets widget properties for a Uniface data object in JavaScript.\">setProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets several field properties.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"fql1665702536920.html\" href=\"/de-DE/bundle/uniface_104/page/fql1665702536920.html\" title=\"Restores the initial widget properties of the Uniface data object.\">clearProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Restores the initial widget properties of the field or occurrence.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"xpn1665702537800.html\" href=\"/de-DE/bundle/uniface_104/page/xpn1665702537800.html\" title=\"Returns the ValRep of a field in the current occurrence.\">getValrep()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">Returns the field's ValRep list as a JavaScript\n                        object. </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qus1665702537878.html\" href=\"/de-DE/bundle/uniface_104/page/qus1665702537878.html\" title=\"Set the ValRep for a field in the current occurrence.\">setValrep()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets the field's ValRep list.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"tyf1665702537952.html\" href=\"/de-DE/bundle/uniface_104/page/tyf1665702537952.html\" title=\"Returns the ValRep of a field in the current occurrence as an array.\">getValrepArray()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">Returns the field's ValRep list as a JavaScript\n                        array </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"yid1665702538027.html\" href=\"/de-DE/bundle/uniface_104/page/yid1665702538027.html\" title=\"Set the ValRep for a field in the current occurrence using an array. This ensures that the specified order of value-representation pairs is kept.\">setValrepArray()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets the field's ValRep list using a JavaScript array.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"lve1714306731020.html\" href=\"/de-DE/bundle/uniface_104/page/lve1714306731020.html\" title=\"Retrieves the value of the specified syntax property for a field.\">getSyntaxProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns the value of one of the field's syntax properties.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"kpb1714306509282.html\" href=\"/de-DE/bundle/uniface_104/page/kpb1714306509282.html\" title=\"Retrieves the value of the specified syntax property for a field.\">setSyntaxProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets the value of one of the field's syntax properties.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"gmv1714306853376.html\" href=\"/de-DE/bundle/uniface_104/page/gmv1714306853376.html\" title=\"Restores the initial value of the specified syntax property.\">clearSyntaxProperty()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Restores the initial value of the specified syntax property.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"zpb1714306631479.html\" href=\"/de-DE/bundle/uniface_104/page/zpb1714306631479.html\" title=\"Retrieves field syntax properties that were set in the browser (using the setSyntaxProperty or setSyntaxProperties functions).\">getSyntaxProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns all of the field's syntax properties as a JavaScript object.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"otb1714306145328.html\" href=\"/de-DE/bundle/uniface_104/page/otb1714306145328.html\" title=\"Sets multiple syntax properties for a field.\">setSyntaxProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Sets several field syntax properties.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qgx1665702538490.html\" href=\"/de-DE/bundle/uniface_104/page/qgx1665702538490.html\" title=\"Restores the initial values of a field's syntax properties.\">clearSyntaxProperties()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Restores the initial values of a field's syntax properties.\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"dig1665702538574.html\" href=\"/de-DE/bundle/uniface_104/page/dig1665702538574.html\" title=\"Return a JavaScript object containing the field syntax properties as defined in the field's definition.\">getDeclarativeSyntax()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns a JavaScript object containing the declarative syntax of the field, with fields describing the syntax.\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"zkz1665702538660.html\" href=\"/de-DE/bundle/uniface_104/page/zkz1665702538660.html\" title=\"Returns an error object for the field, if a syntax error or validation error occurred.\">getError()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">Returns a\n                           <span class=\"keyword apiname\">uniface.SyntaxError</span> object representing a field syntax\n                        error. For more information, see <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"psh1665702538803.html\" href=\"/de-DE/bundle/uniface_104/page/psh1665702538803.html\" title=\"The uniface.SyntaxError object provides access to the error number and message of a field syntax error, and to the incorrect field value that caused the error.\">uniface.SyntaxError</a>. </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bmw1665702538899.html\" href=\"/de-DE/bundle/uniface_104/page/bmw1665702538899.html\" title=\"Returns the outermost DOM node attached to this field for a particular view.\">getBoundElement()</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"dlx1665702535259__table_d15143e1_d15144e1_d15145e1__entry__2\">\n Returns the outermost DOM node attached to the current field for a particular View.\n </td>\n</tr></tbody></table></div><div class=\"dataTables_scrollFoot\" style=\"overflow: hidden; border: 0px; width: 100%;\"><div class=\"dataTables_scrollFootInner\"><table class=\"table dataTable no-footer\" count-columns=\"2\" style=\"margin-left: 0px;\"><tfoot></tfoot></table></div></div></div></div></div>\n</section>\n<div class=\"example\" id=\"dlx1665702535259__example_wjj_g4y_bwb\"><h2 class=\"title sectiontitle\" id=\"d247202e677\">Addressing and Manipulating a Field</h2>\n<p class=\"p\">The following example obtains a field object (AMOUNT), conditionally changes its value,\n            and sets a display property. It performs these specific tasks:</p>\n<div class=\"zDocsCodeExplanationContainer\"><button aria-label=\"Explain this code\" class=\"zDocsAiActionsButton\" data-target=\"#zDocsCodeExplanationModal_uniface_104dlx1665702535259_html_0\" data-toggle=\"modal\" tabindex=\"0\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-code-explanation\"><use xlink:href=\"#ico-code-explanation\"></use></svg>Explain this code</button></div><div class=\"code-toolbar\"><pre class=\"pre codeblock language-plaintext\" data-explanation-rendered=\"true\" id=\"dlx1665702535259__codeblock_qyx_j4y_bwb\" tabindex=\"0\"><code class=\"language-plaintext\">var vInstance = uniface.getInstance(\"MUSICORDER\");  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46118e1_d46119e1_d46120e1\">1</a></strong>  \nif (vInstance != null) {\n var cartEnt = vInstance.getEntity(\"CART.MUSICSHOP\");  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46121e1_d46122e1_d46123e1\">2</a></strong>\n if (cartEnt != null) {\n  // Get the CART occurrence (there should be only one).\n  var cartOcc = cartEnt.getOccurrence(0);  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46124e1_d46125e1_d46126e1\">3</a></strong> \n  if (cartOcc != null) {\n    // Get the first item in the Cart\n    var itemEnt = cartOcc.getEntity(\"CART_ITEM.MUSICSHOP\");  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46127e1_d46128e1_d46129e1\">4</a></strong> \n    if (itemEnt != null) {\n      var itemOcc = itemEnt.getOccurrence(0);  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46130e1_d46131e1_d46132e1\">5</a></strong> \n      if (itemOcc != null) {\n       var quantityFld = itemOcc.getField(\"AMOUNT.CART_ITEM.MUSICSHOP\");  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46133e1_d46134e1_d46135e1\">6</a></strong> \n       if (quantityFld != null) {\n        var quantity = new Number(quantityFld.getValue());  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46136e1_d46137e1_d46138e1\">7</a></strong>\n        if (quantity &gt; 5) {\n         quantityFld.setValue(\"5\"); // Five suffices...  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46139e1_d46140e1_d46141e1\">8</a></strong> \n         quantityFld.setProperty(\"style:color\", \"red\"); // To make the user aware  <strong class=\"ph b\"><a class=\"xref\" href=\"#dlx1665702535259__li_d46142e1_d46143e1_d46144e1\">9</a></strong>\n      }\n     }\n    }\n   }\n  }\n }\n}</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n<ol class=\"ol\" id=\"dlx1665702535259__ol_vw1_34y_bwb\">\n<li class=\"li\" id=\"dlx1665702535259__li_d46118e1_d46119e1_d46120e1\">Get an instance of the DSP MUSICORDER. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46121e1_d46122e1_d46123e1\">Get the top-level entity CART.MUSICSHOP. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46124e1_d46125e1_d46126e1\">Get the occurrence of CART.MUSICSHOP. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46127e1_d46128e1_d46129e1\">Get the child entity CART_ITEM.MUSICSHOP. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46130e1_d46131e1_d46132e1\">Get the first occurrence of CART_ITEM.MUSICSHOP. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46133e1_d46134e1_d46135e1\">Get the field AMOUNT.CART_ITEM. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46136e1_d46137e1_d46138e1\">Get the value of AMOUNT.CART_ITEM. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46139e1_d46140e1_d46141e1\">If the value is more than 5, change the value to\n               5. </li>\n<li class=\"li\" id=\"dlx1665702535259__li_d46142e1_d46143e1_d46144e1\">Set the color property to red to highlight the\n               change. </li>\n</ol>\n</div>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526877\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526877\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "uniface.Field Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Feb 13, 2025 Summarize Uniface 10.4 The uniface.Field object provides access to selected properties of the field that it represents. It is returned by the getField function of uniface.Occurrence . Arguments Table 1. Data Addressing Functions Function Description getLabel() Returns a uniface.Label object representing the label of the field. For more information, see uniface.Label . getName() Returns the fully-qualified name of the uniface.Field in the form FIELD.ENTITY.MODEL. getShortName() Returns the unqualified name of the current uniface.Field in the form FIELD. getType() Returns a constant string denoting the object type: uniface.TYPE_FIELD . getParent() Returns a uniface.Occurrence object that represents the parent of the current uniface.Field . For more information, see uniface.Occurrence . getInstance() Returns the uniface.Instance in which the uniface.Field resides. isEqualTo() Checks whether the uniface.Field object is the same as another uniface.Field object. Search: Column Function Description Filter results... 21 rows found Export to Excel Export to CSV Table 2. Data Manipulation Functions Function Description Filter 21 rows found Filter 21 rows found Function Description getValue() Returns the field's value. setValue() Sets the field value. getProperty() Returns the value of one of the field's properties. setProperty() Sets the value of one of the field's properties. clearProperty() Restores the initial value of the specified property. getProperties() Returns all of the field's properties as a JavaScript object. setProperties() Sets several field properties. clearProperties() Restores the initial widget properties of the field or occurrence. getValrep() Returns the field's ValRep list as a JavaScript object. setValrep() Sets the field's ValRep list. getValrepArray() Returns the field's ValRep list as a JavaScript array setValrepArray() Sets the field's ValRep list using a JavaScript array. getSyntaxProperty() Returns the value of one of the field's syntax properties. setSyntaxProperty() Sets the value of one of the field's syntax properties. clearSyntaxProperty() Restores the initial value of the specified syntax property. getSyntaxProperties() Returns all of the field's syntax properties as a JavaScript object. setSyntaxProperties() Sets several field syntax properties. clearSyntaxProperties() Restores the initial values of a field's syntax properties. getDeclarativeSyntax() Returns a JavaScript object containing the declarative syntax of the field, with fields describing the syntax. getError() Returns a uniface.SyntaxError object representing a field syntax error. For more information, see uniface.SyntaxError . getBoundElement() Returns the outermost DOM node attached to the current field for a particular View. Addressing and Manipulating a Field The following example obtains a field object (AMOUNT), conditionally changes its value, and sets a display property. It performs these specific tasks: Explain this code var vInstance = uniface.getInstance(\"MUSICORDER\"); 1 if (vInstance != null) { var cartEnt = vInstance.getEntity(\"CART.MUSICSHOP\"); 2 if (cartEnt != null) { // Get the CART occurrence (there should be only one). var cartOcc = cartEnt.getOccurrence(0); 3 if (cartOcc != null) { // Get the first item in the Cart var itemEnt = cartOcc.getEntity(\"CART_ITEM.MUSICSHOP\"); 4 if (itemEnt != null) { var itemOcc = itemEnt.getOccurrence(0); 5 if (itemOcc != null) { var quantityFld = itemOcc.getField(\"AMOUNT.CART_ITEM.MUSICSHOP\"); 6 if (quantityFld != null) { var quantity = new Number(quantityFld.getValue()); 7 if (quantity > 5) { quantityFld.setValue(\"5\"); // Five suffices... 8 quantityFld.setProperty(\"style:color\", \"red\"); // To make the user aware 9 } } } } } } } Copy Get an instance of the DSP MUSICORDER. Get the top-level entity CART.MUSICSHOP. Get the occurrence of CART.MUSICSHOP. Get the child entity CART_ITEM.MUSICSHOP. Get the first occurrence of CART_ITEM.MUSICSHOP. Get the field AMOUNT.CART_ITEM. Get the value of AMOUNT.CART_ITEM. If the value is more than 5, change the value to 5. Set the color property to red to highlight the change. Was this topic helpful? Like Dislike"}