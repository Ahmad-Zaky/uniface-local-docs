none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_2529024\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Dez 07, 2022</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104jsi1665702998196.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/jsi1665702998196.html\" id=\"bundle:uniface_104/enus/jsi1665702998196.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"jsi1665702998196\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n<samp class=\"ph msgph\">Error: Parent type <var class=\"keyword varname\">Type1</var> is invalid for type <var class=\"keyword varname\">Type2</var>\n</samp>\n</h1>\n<div class=\"body refbody\"><p class=\"shortdesc\">This message is generated when an object from an old character mode application is incorrectly positioned in the layout.\n </p>\n<section class=\"section\" id=\"jsi1665702998196__section_fhv_nhl_tvb\"><h2 class=\"title sectiontitle\" id=\"d779421e64\"> Problem </h2>\n<p class=\"p\" id=\"jsi1665702998196__p_d69185e1_d69186e1_d69187e1\">For example, a field that has a component as its parent\n        instead of an entity, or a break frame that has an entity as parent. This is only possible\n        if the component originates from a character mode application (probably developed with\n        Uniface 5.1 or older) and the component has never since been opened and edited with the\n        graphical layout editor.</p>\n</section>\n<section class=\"section\" id=\"jsi1665702998196__section_exk_4hl_tvb\"><h2 class=\"title sectiontitle\" id=\"d779421e73\"> Resolution </h2>\n<p class=\"p\" id=\"jsi1665702998196__p_d69191e1_d69192e1_d69193e1\">To fix the issue, open the component in Uniface 9, and\n        modify the layout before migrating the component again.</p>\n</section>\n<section class=\"section\" id=\"jsi1665702998196__section_kjb_shl_tvb\"><h2 class=\"title sectiontitle\" id=\"d779421e82\">Sample Messages</h2>\n<p class=\"p\">Figure: Field with Component as Parent</p>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" id=\"jsi1665702998196__pre_wdz_5hl_tvb\" tabindex=\"0\"><code class=\"language-plaintext\">=== MIGRATION ERROR [cpt:MYCPT] ===\n Failed to migrate cpt:MYCPT. Object will be removed from the repository.\n ErrorID: -100001\n Error : Parent type cpt is invalid for type fld\n Context information:\n [context]\n [errorId] = \"VAL0004\"\n [nodeAddress] = \"cpt:MYCPT/fld:PK\"\n \n Removed cpt:MYCPT from repository</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n<p class=\"p\" id=\"jsi1665702998196__p_d69197e1_d69198e1_d69199e1\">To correct this issue, you may need to ensure that the\n        field has an entity as parent. If it already does, adjust the dimensions of the parent\n        entity, and save the form before migrating it again.</p>\n<p class=\"p\">Break Frame with Entity as Parent</p>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" id=\"jsi1665702998196__pre_ehr_whl_tvb\" tabindex=\"0\"><code class=\"language-plaintext\">=== MIGRATION ERROR [cpt:MYF1] ===\n Failed to migrate cpt:MYF1. Object will be removed from the repository.\n ErrorID: -100001\n Error : Parent type ent is invalid for type pbr\n Context information:\n [context]\n [errorId] = \"VAL0004\"\n [nodeAddress] = \"cpt:MYF1/ent:EE.MM/pbr:BREAK_1.USYS\"\n \n Removed cpt:MYF1 from repository</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n<p class=\"p\" id=\"jsi1665702998196__p_d69200e1_d69201e1_d69202e1\">To correct this issue, drag the frame outside the entity\n        (use Ctrl+Click on the left mouse button and drag) to the correct location in component, and\n        save the form before migrating it again.</p>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529024\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529024\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Error: Parent type Type1 is invalid for type Type2 Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Dez 07, 2022 Summarize Uniface 10.4 Error: Parent type Type1 is invalid for type Type2 This message is generated when an object from an old character mode application is incorrectly positioned in the layout. Problem For example, a field that has a component as its parent instead of an entity, or a break frame that has an entity as parent. This is only possible if the component originates from a character mode application (probably developed with Uniface 5.1 or older) and the component has never since been opened and edited with the graphical layout editor. Resolution To fix the issue, open the component in Uniface 9, and modify the layout before migrating the component again. Sample Messages Figure: Field with Component as Parent === MIGRATION ERROR [cpt:MYCPT] === Failed to migrate cpt:MYCPT. Object will be removed from the repository. ErrorID: -100001 Error : Parent type cpt is invalid for type fld Context information: [context] [errorId] = \"VAL0004\" [nodeAddress] = \"cpt:MYCPT/fld:PK\" Removed cpt:MYCPT from repository Copy To correct this issue, you may need to ensure that the field has an entity as parent. If it already does, adjust the dimensions of the parent entity, and save the form before migrating it again. Break Frame with Entity as Parent === MIGRATION ERROR [cpt:MYF1] === Failed to migrate cpt:MYF1. Object will be removed from the repository. ErrorID: -100001 Error : Parent type ent is invalid for type pbr Context information: [context] [errorId] = \"VAL0004\" [nodeAddress] = \"cpt:MYF1/ent:EE.MM/pbr:BREAK_1.USYS\" Removed cpt:MYF1 from repository Copy To correct this issue, drag the frame outside the entity (use Ctrl+Click on the left mouse button and drag) to the correct location in component, and save the form before migrating it again. Was this topic helpful? Like Dislike"}