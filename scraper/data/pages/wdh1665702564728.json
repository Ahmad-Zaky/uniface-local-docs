ckModal_main_3616686\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Sept 20, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104wdh1665702564728.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/wdh1665702564728.html\" id=\"bundle:uniface_104/enus/wdh1665702564728.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"wdh1665702564728\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Example: Moving Structs\n </h1>\n<div class=\"body taskbody\"><p class=\"shortdesc\">This example demonstrates how an existing Struct can be inserted as a member of another Struct.\n </p>\n<section class=\"section context\" id=\"wdh1665702564728__context_w2556ab1b5b1_w2557ab1b5_w2558ab1\">\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" tabindex=\"0\"><code class=\"language-plaintext\">function MOVE_STRUCT\nvariables\n    struct vStruct1, vStruct2, vSteadyRef\nendvariables\n\n  call printHeader(\"MOVE_STRUCT\") ; display entry header in the message frame\n\n  ; Build Struct vStruct1\n  vStruct1-&gt;a = \"AAA\"\n  vStruct1-&gt;c = \"CCC\"\n\n  ; Build Struct vStruct2\n  vStruct2-&gt;b = \"BBB\"\n\n  ; Make vStruct2-&gt;b a member of vStruct1:\n  vStruct2-&gt;b-&gt;$parent = vStruct1       [<strong class=\"ph b\">1</strong>]\n  putmess \"Struct vStruct2-&gt;b moved to vStruct1, and appended as member 'b':\"\n  putmess vStruct1-&gt;$dbgstring\n \n  ; Reposition the newly-added Struct (assuming this is relevant)\n  vStruct1-&gt;b-&gt;$index = 2                [<strong class=\"ph b\">2</strong>]\n  putmess \"Newly-added Struct 'b' has been repositioned:\"\n  putmess vStruct1-&gt;$dbgstring\n \n  ; Alternative: Use a dedicated reference for manipulation\n  vStruct2-&gt;b = \"BBB\"\n  vSteadyRef = vStruct2-&gt;b    ; vSteadyRef refers to the 'b' Struct    [<strong class=\"ph b\">3</strong>]\n  vSteadyRef-&gt;$parent = vStruct1\n  vSteadyRef-&gt;$index = 2\nend ; function MOVE_STRUCT</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</section>\n<section><ol class=\"ol steps\"><li class=\"li step stepexpand\" id=\"wdh1665702564728__li_d8612e1_d8613e1_d8614e1\">\n<span class=\"ph cmd\">Move a Struct by changing its parent using the <span class=\"keyword cmdname\">$parent</span> Struct\n               function. The moved Struct is appended to the other Struct. </span>\n<div class=\"itemgroup info\">\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" tabindex=\"0\"><code class=\"language-plaintext\">===============================\n MOVE_STRUCT\n===============================\nStruct vStruct2-&gt;b moved to vStruct1, and appended as member 'b': \n[]\n [a] = \"AAA\"\n [c] = \"CCC\"\n [b] = \"BBB\"</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</div>\n</li><li class=\"li step stepexpand\" id=\"wdh1665702564728__li_d8615e1_d8616e1_d8617e1\">\n<span class=\"ph cmd\">Move a Struct member to another position in its parent Struct by assigning it to\n               the desired index using the <span class=\"keyword cmdname\">$index</span> Struct function. </span>\n<div class=\"itemgroup info\">\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" tabindex=\"0\"><code class=\"language-plaintext\">Newly-added Struct 'b' has been repositioned:\n[]\n [a] = \"AAA\"\n [b] = \"BBB\"\n [c] = \"CCC\"</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</div>\n</li><li class=\"li step stepexpand\" id=\"wdh1665702564728__li_d8618e1_d8619e1_d8620e1\">\n<span class=\"ph cmd\" id=\"wdh1665702564728__p_d18344e1_d18345e1_d18346e1\">It is no longer possible to use\n                  <code class=\"ph codeph\">vStruct2-&gt;b</code> because the <span class=\"keyword cmdname\">$parent</span> assignment\n               has moved the Struct from <code class=\"ph codeph\">vStruct2</code> to <code class=\"ph codeph\">vStruct1</code>. A\n               more elegant alternative is to use a dedicated reference by assigning\n                  <code class=\"ph codeph\">vStruct2-&gt;b</code> to its own variable. The end result is the same:\n                  <code class=\"ph codeph\">vStruct1</code>is assigned the member <code class=\"ph codeph\">b</code>at position\n               2.</span>\n</li></ol></section>\n</div>\n</article></main></article>\n</div></div><div class=\"contentPlaceholder\" style=\"height: 500px;\"><div class=\"contentContainer zDocsSideBoxes\"><div><h5 aria-level=\"5\" class=\"css-g931ng\">Related Links</h5><ul><li><a class=\"css-ettsdk\" href=\"/de-DE/bundle/uniface_104/page/zva1665702565198.html\" stylesprops=\"[object Object]\"><svg aria-hidden=\"true\" class=\"ico-related-link\"><use xlink:href=\"#ico-related-link\"></use></svg>$parent</a><p>Get or set the parent of the Struct node.</p></li><li><a class=\"css-ettsdk\" href=\"/de-DE/bundle/uniface_104/page/gym1665702564527.html\" stylesprops=\"[object Object]\"><svg aria-hidden=\"true\" class=\"ico-related-link\"><use xlink:href=\"#ico-related-link\"></use></svg>$index</a><p>Get or set the index (position) of a node in a Struct collection.</p></li><li><a class=\"css-ettsdk\" href=\"/de-DE/bundle/uniface_104/page/fjy1665702564615.html\" stylesprops=\"[object Object]\"><svg aria-hidden=\"true\" class=\"ico-related-link\"><use xlink:href=\"#ico-related-link\"></use></svg>Adding, Copying, Moving, and Replacing Struct Members</a><p>You can add and replace members in existing Structs, insert them at specified positions, detach them, or move them to new positions, or to new Structs.</p></li></ul></div></div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3616686\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3616686\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Example: Moving Structs Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Sept 20, 2024 Summarize Uniface 10.4 Example: Moving Structs This example demonstrates how an existing Struct can be inserted as a member of another Struct. function MOVE_STRUCT variables struct vStruct1, vStruct2, vSteadyRef endvariables call printHeader(\"MOVE_STRUCT\") ; display entry header in the message frame ; Build Struct vStruct1 vStruct1->a = \"AAA\" vStruct1->c = \"CCC\" ; Build Struct vStruct2 vStruct2->b = \"BBB\" ; Make vStruct2->b a member of vStruct1: vStruct2->b->$parent = vStruct1 [ 1 ] putmess \"Struct vStruct2->b moved to vStruct1, and appended as member 'b':\" putmess vStruct1->$dbgstring ; Reposition the newly-added Struct (assuming this is relevant) vStruct1->b->$index = 2 [ 2 ] putmess \"Newly-added Struct 'b' has been repositioned:\" putmess vStruct1->$dbgstring ; Alternative: Use a dedicated reference for manipulation vStruct2->b = \"BBB\" vSteadyRef = vStruct2->b ; vSteadyRef refers to the 'b' Struct [ 3 ] vSteadyRef->$parent = vStruct1 vSteadyRef->$index = 2 end ; function MOVE_STRUCT Copy Move a Struct by changing its parent using the $parent Struct function. The moved Struct is appended to the other Struct. =============================== MOVE_STRUCT =============================== Struct vStruct2->b moved to vStruct1, and appended as member 'b': [] [a] = \"AAA\" [c] = \"CCC\" [b] = \"BBB\" Copy Move a Struct member to another position in its parent Struct by assigning it to the desired index using the $index Struct function. Newly-added Struct 'b' has been repositioned: [] [a] = \"AAA\" [b] = \"BBB\" [c] = \"CCC\" Copy It is no longer possible to use vStruct2->b because the $parent assignment has moved the Struct from vStruct2 to vStruct1 . A more elegant alternative is to use a dedicated reference by assigning vStruct2->b to its own variable. The end result is the same: vStruct1 is assigned the member b at position 2. Related Links $parent Get or set the parent of the Struct node. $index Get or set the index (position) of a node in a Struct collection. Adding, Copying, Moving, and Replacing Struct Members You can add and replace members in existing Structs, insert them at specified positions, detach them, or move them to new positions, or to new Structs. Was this topic helpful? Like Dislike"}