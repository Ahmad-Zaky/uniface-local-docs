{"id": "rip1665702746090", "title": "Creating Persistence Data with ulic /prep", "breadcrumbs": ["Uniface License Management", "Uniface License Management Utility (ulic)", "Creating Persistence Data with ulic /prep"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/rip1665702746090.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Creating Persistence Data with ulic /prep</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous: Uniface License Management Utility (ulic) \" class=\"\" data-tooltip-content=\"Previous: Uniface License Management Utility (ulic) \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/qgt1690346679212.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:  Troubleshooting Licensing Issues \" class=\"\" data-tooltip-content=\"Next:  Troubleshooting Licensing Issues \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/kdm1665702750049.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg