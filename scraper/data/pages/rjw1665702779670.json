class=\"p\">J1-J32</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__2\">\n<p class=\"p\">J<var class=\"keyword varname\">m</var>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__3\">\n<p class=\"p\">char(<var class=\"keyword varname\">m</var>) where (0 &lt; <var class=\"keyword varname\">m</var> &lt; 33)</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__1\">\n<p class=\"p\">M1-M8</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__2\">\n<p class=\"p\">N20</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__3\">\n<p class=\"p\">char(20)</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__1\">\n<p class=\"p\">N1-N32</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__2\">\n<p class=\"p\">N<var class=\"keyword varname\">m</var>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__3\">\n<p class=\"p\">char(<var class=\"keyword varname\">m</var>) where (0 &lt; <var class=\"keyword varname\">m</var> &lt; 33)</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__1\">\n<p class=\"p\">O1-O31</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__2\">\n<p class=\"p\">N(<var class=\"keyword varname\">m</var>+1)</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"rjw1665702779670__table_d5429e1_d5430e1_d5431e1__entry__3\">\n<p class=\"p\">char(<var class=\"keyword varname\">m</va