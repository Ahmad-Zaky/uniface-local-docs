98.453px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\">\n Technical Name\n </div></th><th aria-controls=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1\" aria-label=\"\n Dynamic?\n : activate to sort column ascending\" class=\"entry sorting\" colspan=\"1\" dir=\"ltr\" id=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 78.0156px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\">\n Dynamic?\n </div></th></tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"txj1665702628158.html\" href=\"/de-DE/bundle/uniface_104/page/txj1665702628158.html\" title=\"This property determines whether a three-dimensional appearance is applied when the widget is displayed. True (default) or False.\">3-D Effect (3d)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              3D\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n No\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"plk1665702651617.html\" href=\"/de-DE/bundle/uniface_104/page/plk1665702651617.html\" title=\"Rate at which the value of the spin button is incremented, expressed as a percentage. Default is 5.\">Acceleration (Accel)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              Accel\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bou1665702610816.html\" href=\"/de-DE/bundle/uniface_104/page/bou1665702610816.html\" title=\"The Attach to Window Border (Attach) widget property attaches the widget (or area frame) to one or more form window borders or split bars at runtime. This allows the element to be resized or moved when the window is resized or a split bar moved.\">Attach to Window Border (attach)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              Attach\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"glz1665702631024.html\" href=\"/de-DE/bundle/uniface_104/page/glz1665702631024.html\" title=\"Determines whether the text in the widget is selected when the field gets focus.\">Auto Select (autoselect)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              AutoSelect\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"rwc1665702587483.html\" href=\"/de-DE/bundle/uniface_104/page/rwc1665702587483.html\" title=\"Color to use as the background of the object.\">Background Color (BackColor)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              BackColor\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"xaf1665702630029.html\" href=\"/de-DE/bundle/uniface_104/page/xaf1665702630029.html\" title=\"Determines whether the background color of the widget is changed when the field syntax is DIM, so the field cannot get focus or be edited.\">Dimmed Background Color (DimmedBackColor)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              DimmedBackColor\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"wul1665702617735.html\" href=\"/de-DE/bundle/uniface_104/page/wul1665702617735.html\" title=\"Return the result of applying the underline character attribute to a string.\">$underline</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              BottomLine\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"gxy1665702651693.html\" href=\"/de-DE/bundle/uniface_104/page/gxy1665702651693.html\" title=\"The time in milliseconds between the user clicking a button and the start of the auto-repeat. Default is 500 milliseconds (half a second).\">Delay</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              Delay\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bwv1665702631393.html\" href=\"/de-DE/bundle/uniface_104/page/bwv1665702631393.html\" title=\"Determines how Uniface reacts when the user double-clicks in this widget.\">Double-Click (DblClk)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              DblClk\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"edp1665702631104.html\" href=\"/de-DE/bundle/uniface_104/page/edp1665702631104.html\" title=\"This property determines whether a 3-D frame is drawn outside the widget area.\">Draw 3-D Frame Outside (DrawOutside)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              DrawOutside\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n No\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"rbp1665702587714.html\" href=\"/de-DE/bundle/uniface_104/page/rbp1665702587714.html\" title=\"Color to use as the foreground (usually the text color).\">Foreground Color (ForeColor)</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              ForeColor\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n Yes\n </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"svg1665702629592.html\" href=\"/de-DE/bundle/uniface_104/page/svg1665702629592.html\" title=\"Determines whether a border is displayed around the widget at run time. True or False. The default value depends on the widget.\">Frame</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__2\">\n                              Frame\n                             </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__3\">\n No\n </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lxs1665702651483__table_d13583e1_d13584e1_d13585e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"vyv1665702651765.html\" href=\"/de-DE/bundle/uniface_104/page/vyv1665702651765.html\" titl