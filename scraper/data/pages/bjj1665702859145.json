\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-pdf\"><use xlink:href=\"#ico-pdf\"></use></svg>Download PDF</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"zDocsExportItem zDocsExportTopicButton\" href=\"#\" id=\"singlePdf\" role=\"button\">Save selected topic</a><a class=\"zDocsExportItem zDocsExportSubtopicsButton\" href=\"#\" id=\"pdfWithChildren\" role=\"button\">Save selected topic and subtopics</a><a class=\"zDocsExportItem zDocsExportBundleButton\" href=\"#\" id=\"wholeBundlePdf\" role=\"button\">Save entire publication</a></div></div><div class=\"zDocsTopicShare zDocsShareButton\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Share\" class=\"d-none d-lg-flex zDocsShareDialogButton\" data-toggle=\"dropdown\" data-tooltip-content=\"Share\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg></span><span class=\"d-lg-none zDocsShareDialogButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg>Share</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"dropdown-item zDocsShareButton zDocsShareEmail\" href=\"#\" role=\"button\"><span>Email Link</span></a><a class=\"dropdown-item zDocsShareButton zDocsShareLink\" href=\"#\" role=\"button\"><span>Copy Link</span></a></div></div><div class=\"zDocsFeedback zDocsFeedback zDocsTopicFeedback\" role=\"listitem\"><span aria-label=\"Feedback\" class=\"zDocsFeedbackButton d-none d-lg-flex\" data-backdrop=\"static\" data-target=\"#feedbackModal_main_3612129\" data-toggle=\"modal\" data-tooltip-content=\"Feedback\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg></span><span class=\"d-lg-none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_3612129\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Sept 20, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104bjj1665702859145.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/bjj1665702859145.html\" id=\"bundle:uniface_104/enus/bjj1665702859145.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"bjj1665702859145\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Example: Finding a Matching Struct\n </h1>\n<div class=\"body conbody\"><p class=\"shortdesc\">The following example ProcScript module returns the first Struct node with a specified value in a Struct or collection of Structs. It demonstrates the use of iteration and recursion, access operators, and Struct functiions.\n </p>\n<div class=\"example\">\n<ol class=\"ol\">\n<li class=\"li\" id=\"bjj1665702859145__li_d8780e1_d8781e1_d8782e1\">Define Struct parameters and variables. This module takes two IN parameters, a Struct or collection of Structs, and a value to search for.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8783e1_d8784e1_d8785e1\">Get the total number of Structs using the <span class=\"keyword cmdname\">$collsize</span> function.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8786e1_d8787e1_d8788e1\">If it is a collection of structs, for each Struct, recursively call this ProcScript module until a match is found.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8789e1_d8790e1_d8791e1\">If it is a single Struct, get the number of members using the <span class=\"keyword cmdname\">$membercount</span> function.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8792e1_d8793e1_d8794e1\">For each member, check whether it is a Struct leaf using the <span class=\"keyword cmdname\">$isLeaf</span> function, and evaluate whether the value matches.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8795e1_d8796e1_d8797e1\">If it is a Struct node (that is, not a leaf), recursively call this ProcScript module until a match is found.\n </li>\n<li class=\"li\" id=\"bjj1665702859145__li_d8798e1_d8799e1_d8800e1\">If no match is found, return an empty string.\n </li>\n</ol>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" tabindex=\"0\"><code class=\"language-plaintext\">function findFirstMatch\n returns struct\n params   [<strong class=\"ph b\">1</strong>]\n   struct pStruct: in\n   string pMatchValue: in\n endparams\n variables\n  struct vNextChild, vMatch\n  numeric I, vTotalStructs, vTotalMembers\n endvariables\n\n  vTotalStructs = pStruct-&gt;$collsize [<strong class=\"ph b\">2</strong>]\n  if (vTotalStructs &gt; 1) [<strong class=\"ph b\">3</strong>]\n    I = 1\n    while (I &lt;= vTotalStructs)\n      vMatch = findFirstMatch(pStruct{I}, pMatchValue)\n      if (vMatch != \"\")\n        return vMatch\n      endif\n      I = I + 1\n    endwhile\n  else                                 \n    vTotalMembers = pStruct-&gt;$membercount [<strong class=\"ph b\">4</strong>]\n    I = 1                                 \n    while (I &lt;= vTotalMembers)\n      vNextChild = pStruct-&gt;*{I}\n      if (vNextChild-&gt;$isLeaf) [<strong class=\"ph b\">5</strong>]\n        if (vNextChild == pMatchValue)\n          return vNextChild\n        endif\n      else\n        vMatch = findFirstMatch(vNextChild, pMatchValue) [<strong class=\"ph b\">6</strong>]\n        if (vMatch != \"\")\n          return vMatch                \n        endif\n      endif\n      I = I + 1\n    endwhile\n  endif\n  return \"\" [<strong class=\"ph b\">7</strong>]\nend ;- function findFirstMatch</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</div>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3612129\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3612129\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Example: Finding a Matching Struct Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Sept 20, 2024 Summarize Uniface 10.4 Example: Finding a Matching Struct The following example ProcScript module returns the first Struct node with a specified value in a Struct or collection of Structs. It demonstrates the use of iteration and recursion, access operators, and Struct functiions. Define Struct parameters and variables. This module takes two IN parameters, a Struct or collection of Structs, and a value to search for. Get the total number of Structs using the $collsize function. If it is a collection of structs, for each Struct, recursively call this ProcScript module until a match is found. If it is a single Struct, get the number of members using the $membercount function. For each member, check whether it is a Struct leaf using the $isLeaf function, and evaluate whether the value matches. If it is a Struct node (that is, not a leaf), recursively call this ProcScript module until a match is found. If no match is found, return an empty string. function findFirstMatch returns struct params [ 1 ] struct pStruct: in string pMatchValue: in endparams variables struct vNextChild, vMatch numeric I, vTotalStructs, vTotalMembers endvariables vTotalStructs = pStruct->$collsize [ 2 ] if (vTotalStructs > 1) [ 3 ] I = 1 while (I <= vTotalStructs) vMatch = findFirstMatch(pStruct{I}, pMatchValue) if (vMatch != \"\") return vMatch endif I = I + 1 endwhile else vTotalMembers = pStruct->$membercount [ 4 ] I = 1 while (I <= vTotalMembers) vNextChild = pStruct->*{I} if (vNextChild->$isLeaf) [ 5 ] if (vNextChild == pMatchValue) return vNextChild endif else vMatch = findFirstMatch(vNextChild, pMatchValue) [ 6 ] if (vMatch != \"\") return vMatch endif endif I = I + 1 endwhile endif return \"\" [ 7 ] end ;- function findFirstMatch Copy Was this topic helpful? Like Dislike"}