{"id": "gbf1665702906922", "title": "Sign Certification Requests", "breadcrumbs": ["Protecting Your Application", "Transport Protocols and Certificates", "Digital Certificates", "Creating Certificates", "Acting as a Certificate Authority", "Sign Certification Requests"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/gbf1665702906922.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Sign Certification Requests</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:  Create Intermediate CA Certificates  \" class=\"\" data-tooltip-content=\"Previous:  Create Intermediate CA Certificates  \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/hso1665702906774.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:  Pathscrambler \" class=\"\" data-tooltip-content=\"Next:  Pathscrambler \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/jbd1665702548027.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-