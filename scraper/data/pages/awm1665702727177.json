" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__2\"> BLOB <sup class=\"ph sup\">2</sup> &gt; <p class=\"p\">DBCLOB <sup class=\"ph sup\">3</sup>\n                        &gt;</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__1\">\n SC...\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__2\"> Char(1) For Bit Data + Long Varchar <sup class=\"ph sup\">3</sup>\n<sup class=\"ph sup\">4</sup>\n<p class=\"p\">DBCLOB <sup class=\"ph sup\">5</sup>\n<sup class=\"ph sup\">6</sup>\n</p>\n<p class=\"p\">CLOB <sup class=\"ph sup\">7</sup> &gt;</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__1\">\n SR...\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__2\"> Char(1) For Bit Data + Long Varchar For Bit\n                        Data<sup class=\"ph sup\">5</sup>\n<p class=\"p\">BLOB <sup class=\"ph sup\">7</sup> &gt;</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__1\">\n SW...\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__2\"> DBCLOB <sup class=\"ph sup\">6</sup>\n<p class=\"p\">CLOB <sup class=\"ph sup\">7</sup>\n</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__1\">\n T1, T2, T4-T6\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__2\">\n Time\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"awm1665702727177__table_d4667e1_d4668e1_d4669e1__entry__1\">\n T3\n </td>\n<td class=\"entry\" dir=\