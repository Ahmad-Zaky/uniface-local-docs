{"id": "ucb1665702704561", "title": "Locking Support on Microsoft SQL Server", "breadcrumbs": ["DBMS Support", "Database Connectors", "Microsoft SQL Server", "Referential Integrity Management on Microsoft SQL Server", "Locking Support on Microsoft SQL Server"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/ucb1665702704561.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Locking Support on Microsoft SQL Server</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:   Referential Integrity Management on Microsoft SQL Server \" class=\"\" data-tooltip-content=\"Previous:   Referential Integrity Management on Microsoft SQL Server \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/pfy1665702948452.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:   Transaction Control on Microsoft SQL Server \" class=\"\" data-tooltip-content=\"Next:   Transaction Control on Microsoft SQL Server \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/vpe1665702704630.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bo