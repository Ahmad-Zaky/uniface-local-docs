{"id": "iau1718889984177", "title": "$nlstimezone", "breadcrumbs": ["Uniface Reference", "ProcScript Reference", "ProcScript: Functions", "$nlstimezone"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/iau1718889984177.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">$nlstimezone</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:   $nlssortorder \" class=\"\" data-tooltip-content=\"Previous:   $nlssortorder \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/mfl1718885236878.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:   $nlstimezonelist \" class=\"\" data-tooltip-content=\"Next:   $nlstimezonelist \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/ysd1718877960056.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg>Add to My Topics</span><div aria-labelledby=\"pdfDropdown\" class=\"dropdow