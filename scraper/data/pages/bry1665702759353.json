1665702759353.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/bry1665702759353.html\" id=\"bundle:uniface_104/enus/bry1665702759353.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"bry1665702759353\" role=\"article\">\n<div class=\"body conbody\"><p class=\"shortdesc\">Adds the supplied text inside an element.</p>\n<section class=\"section refsyn\" id=\"bry1665702759353__topic_d136670e1_d136671e1_d136672e1\">\n<div class=\"code-toolbar\"><pre class=\"pre codeblock language-plaintext\" id=\"bry1665702759353__codeblock_igv_d2h_hwb\" tabindex=\"0\"><code class=\"language-plaintext\">UXMLWRITER.CHARACTERS(Chars)</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</section>\n<section class=\"section\" id=\"bry1665702759353__section_rct_b2h_hwb\"><h2 class=\"title sectiontitle\" id=\"d124405e56\">Parameters</h2>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"4\" id=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1\"><caption><span class=\"table--title-label\">Table 1. </span><span class=\"title\">CHARACTERS parameters</span></caption><colgroup><col/><col/><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__1\">Parameter</th>\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__2\">Data Type</th>\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__3\">Direction</th>\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__4\">Description</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__1\"><var class=\"keyword varname\">Chars</var></td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__2\">String</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__3\">IN</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16301e1_d16302e1_d16303e1__entry__4\">Text to be added inside the element tags;\n                        maximum length is 10240000 bytes.</td>\n</tr>\n</tbody></table></div>\n</section>\n<section class=\"section\" id=\"bry1665702759353__section_axx_j2h_hwb\"><h2 class=\"title sectiontitle\" id=\"d124405e117\">Return Values</h2>\n<p class=\"p\" id=\"bry1665702759353__p_d136721e1_d136722e1_d136723e1\">Values returned:</p>\n<ul class=\"ul\" id=\"bry1665702759353__ul_yly_k2h_hwb\">\n<li class=\"li\" id=\"bry1665702759353__li_d48317e1_d48318e1_d48319e1\"><code class=\"ph codeph\">0</code> Success. </li>\n<li class=\"li\" id=\"bry1665702759353__li_d48320e1_d48321e1_d48322e1\"><code class=\"ph codeph\">–1</code> Failure. Called in an illegal\n               sequence. </li>\n</ul>\n</section>\n<section class=\"section\" id=\"bry1665702759353__section_uhn_l2h_hwb\"><h2 class=\"title sectiontitle\" id=\"d124405e139\">Description</h2>\n<p class=\"p\" id=\"bry1665702759353__p_d136688e1_d136689e1_d136690e1\">The <span class=\"keyword cmdname\">CHARACTERS</span> operation must\n            follow a <span class=\"keyword cmdname\">STARTELEMENT</span> or another <span class=\"keyword cmdname\">CHARACTERS</span>\n            invocation. It can be called repeatedly to create elements that exceed 10240000 bytes\n            (almost 10 MB).</p>\n<p class=\"p\" id=\"bry1665702759353__p_d136691e1_d136692e1_d136693e1\">The following characters are replaced by their XML\n            notations:</p>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1\"><caption><span class=\"table--title-label\">Table 2. </span><span class=\"title\"></span></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\">Character</th>\n<th class=\"entry\" dir=\"ltr\" id=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\">XML notation</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\"> &lt; </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\"><code class=\"ph codeph\">&amp;lt;</code>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\"> &gt; </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\"><code class=\"ph codeph\">&amp;gt;</code>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\"> &amp; </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\"><code class=\"ph codeph\">&amp;amp;</code>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\"> \" </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\"><code class=\"ph codeph\">&amp;quot;</code>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__1\"> ' </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"bry1665702759353__table_d16304e1_d16305e1_d16306e1__entry__2\"><code class=\"ph codeph\">&amp;apos;</code>\n</td>\n</tr>\n</tbody></table></div>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526207\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526207\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "CHARACTERS Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Jan 25, 2023 Summarize Uniface 10.4 Adds the supplied text inside an element. UXMLWRITER.CHARACTERS(Chars) Copy Parameters Table 1. CHARACTERS parameters Parameter Data Type Direction Description Chars String IN Text to be added inside the element tags; maximum length is 10240000 bytes. Return Values Values returned: 0 Success. –1 Failure. Called in an illegal sequence. Description The CHARACTERS operation must follow a STARTELEMENT or another CHARACTERS invocation. It can be called repeatedly to create elements that exceed 10240000 bytes (almost 10 MB). The following characters are replaced by their XML notations: Table 2. Character XML notation < &lt; > &gt; & &amp; \" &quot; ' &apos; Was this topic helpful? Like Dislike"}