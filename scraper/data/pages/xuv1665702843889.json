1248e1_d1249e1\"><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\" style=\"height: 0px;\"><th aria-controls=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1\" aria-label=\" Format : activate to sort column ascending\" class=\"entry sorting\" colspan=\"1\" dir=\"ltr\" id=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 73.375px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\"> Format </div></th><th aria-controls=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1\" aria-label=\" Description : activate to sort column ascending\" class=\"entry sorting\" colspan=\"1\" dir=\"ltr\" id=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 834.625px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\"> Description </div></th></tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> BAF </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Microsoft Windows or OS/2 Array file </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> BMP </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Microsoft Windows or OS/2 Bitmap file\n\t\t\t\t </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> DIB </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Microsoft Windows or OS/2 Dibmap file\n\t\t\t\t </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> GEM </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Digital Research (Novell) </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> GIF </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> CompuServe Inc. </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> ICO </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Microsoft Windows or OS/2 Icon </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> IFF </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Electronic Arts (IFF/LBM) </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> JPG </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> JPEG format</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> MAC </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Macintosh MacPaint Monochrome </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> PBM </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Poskanzer Portable </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> PCX </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Zsoft </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> PIC </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Pictor/PcPaint </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> PICT </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> QuickDraw Pict (Macintosh) </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> PNG </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Portable Network Graphic (with some\n\t\t\t\t restrictions). The following features are not supported: <ul class=\"ul\">\n<li class=\"li\" id=\"xuv1665702843889__li_d5429e1_d5430e1_d5431e1\">Gamma corrections</li>\n<li class=\"li\" id=\"xuv1665702843889__li_d5432e1_d5433e1_d5434e1\">Textual support</li>\n<li class=\"li\" id=\"xuv1665702843889__li_d5435e1_d5436e1_d5437e1\">Ancillary chunks</li>\n<li class=\"li\" id=\"xuv1665702843889__li_d5438e1_d5439e1_d5440e1\">Transparency in the Tree\n\t\t\t\t\t widget</li>\n<li class=\"li\" id=\"xuv1665702843889__li_d5441e1_d5442e1_d5443e1\">Dimming on disabled controls and\n\t\t\t\t\t widgets</li>\n</ul>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> SGI </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Silicon Graphics </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> SUN </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Sun Raster </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> TGA </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Truevision Targa </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> TIF </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Aldus/Microsoft Tiff </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> UNI </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> Uniface internal storage format (used\n\t\t\t\t with glyphs) </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> XBM </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> X-Windows Bitmap (monochrome) </td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> XPM </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> X-Windows Picture Bitmap (color) </td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__1\"> XWD </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xuv1665702843889__table_d1247e1_d1248e1_d1249e1__entry__2\"> X-Windows Dump </td>\n</tr></tbody></table></div><div class=\"dataTables_scrollFoot\" style=\"overflow: hidden; border: 0px; width: 100%;\"><div class=\"dataTables_scrollFootInner\"><table class=\"table dataTable no-footer\" count-columns=\"2\" style=\"margin-left: 0px;\"><tfoot></tfoot></table></div></div></div></div></div>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2533929\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2533929\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Supported Image Formats Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 13, 2022 Summarize Uniface 10.4 Supported Image Formats Uniface provides a wide range of filters that transparently support many image formats. Loading an image that has been stored in a supported format causes it to appear, whatever the runtime graphical environment. The image filters only work with bitmap-oriented image formats. Vector-oriented mark-up languages such as PostScript and HP-GL are not supported. The image filters recognize the format of the image to be loaded from the file extension, or, if that is not available, the header information of the image data. The image filters in Uniface only work in one direction. They can load any of the supported image formats and convert it to a proprietary format that can be displayed on all platforms. They cannot convert one format to another, or export from the Uniface format to another format. Search: Column Format Description Filter results... 22 rows found Export to Excel Export to CSV Table 1. Supported Image Formats Format Description Filter 22 rows found Filter 22 rows found Format Description BAF Microsoft Windows or OS/2 Array file BMP Microsoft Windows or OS/2 Bitmap file DIB Microsoft Windows or OS/2 Dibmap file GEM Digital Research (Novell) GIF CompuServe Inc. ICO Microsoft Windows or OS/2 Icon IFF Electronic Arts (IFF/LBM) JPG JPEG format MAC Macintosh MacPaint Monochrome PBM Poskanzer Portable PCX Zsoft PIC Pictor/PcPaint PICT QuickDraw Pict (Macintosh) PNG Portable Network Graphic (with some restrictions). The following features are not supported: Gamma corrections Textual support Ancillary chunks Transparency in the Tree widget Dimming on disabled controls and widgets SGI Silicon Graphics SUN Sun Raster TGA Truevision Targa TIF Aldus/Microsoft Tiff UNI Uniface internal storage format (used with glyphs) XBM X-Windows Bitmap (monochrome) XPM X-Windows Picture Bitmap (color) XWD X-Windows Dump Was this topic helpful? Like Dislike"}