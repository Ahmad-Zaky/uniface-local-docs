wb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/size4_i.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__3\">\n<p class=\"p\">Double-pointed arrow pointing north and south</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">USizeNWSE</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__2\">\n<figure class=\"fig fignone\" id=\"ewz1665702628443__fig_w820ab1b5b3b3b9c21b3b1_w821ab1b5b3b3b9c21b3_w822ab1b5b3b3b9c21_w823ab1b5b3b3b9_w824ab1b5b3b3_w825ab1b5b3_w826ab1b5_w827ab1\">\n<img alt=\"Image\" class=\"image\" id=\"ewz1665702628443__image_xnj_r1d_zwb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/size2_i.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__3\">\n<p class=\"p\">Double-pointed arrow pointing northwest and southeast</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">USizeWE</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__2\">\n<figure class=\"fig fignone\" id=\"ewz1665702628443__fig_w828ab1b5b3b3b9c23b3b1_w829ab1b5b3b3b9c23b3_w830ab1b5b3b3b9c23_w831ab1b5b3b3b9_w832ab1b5b3b3_w833ab1b5b3_w834ab1b5_w835ab1\">\n<img alt=\"Image\" class=\"image\" id=\"ewz1665702628443__image_osq_s1d_zwb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/size3_i.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__3\">\n<p class=\"p\">Double-pointed arrow pointing west and east</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">UUpArrow</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__2\">\n<figure class=\"fig fignone\" id=\"ewz1665702628443__fig_w836ab1b5b3b3b9c25b3b1_w837ab1b5b3b3b9c25b3_w838ab1b5b3b3b9c25_w839ab1b5b3b3b9_w840ab1b5b3b3_w841ab1b5b3_w842ab1b5_w843ab1\">\n<img alt=\"Image\" class=\"image\" id=\"ewz1665702628443__image_acc_51d_zwb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/up_i.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__3\">\n<p class=\"p\">Vertical arrow</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">UWait</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__2\">\n<figure class=\"fig fignone\" id=\"ewz1665702628443__fig_w844ab1b5b3b3b9c27b3b1_w845ab1b5b3b3b9c27b3_w846ab1b5b3b3b9c27_w847ab1b5b3b3b9_w848ab1b5b3b3_w849ab1b5b3_w850ab1b5_w851ab1\">\n<img alt=\"Image\" class=\"image\" id=\"ewz1665702628443__image_z45_v1d_zwb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/busy_i.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"ewz1665702628443__table_d12497e1_d12498e1_d12499e1__entry__3\">\n<p class=\"p\">Hourglass</p>\n</td>\n</tr>\n</tbody></table></div>\n<section class=\"section\" id=\"ewz1665702628443__section_pnc_y1d_zwb\"><h2 class=\"title sectiontitle\" id=\"d1161870e529\">Description</h2>\n<p class=\"p\" id=\"ewz1665702628443__p_d105806e1_d105807e1_d105808e1\">Specifies the system cursor image to be used on\n            mouse roll-over, that is, when the mouse pointer is positioned over the widget.</p>\n</section>\n<section class=\"section\" id=\"ewz1665702628443__section_vf1_z1d_zwb\"><h2 class=\"title sectiontitle\" id=\"d1161870e538\">Setting in ProcScript</h2>\n<p class=\"p\" id=\"ewz1665702628443__p_d105812e1_d105813e1_d105814e1\">You can set the value of the\n               <code class=\"ph codeph\">Cursor</code> property in ProcScript using the\n               <span class=\"keyword cmdname\">$properties</span> or <span class=\"keyword cmdname\">$fieldproperties</span> functions, for\n            example:</p>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" id=\"ewz1665702628443__pre_cgy_1bd_zwb\" tabindex=\"0\"><code class=\"language-plaintext\">$fieldproperties(EDITFIELD)=\"cursor=uarrow\"</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n<p class=\"p\" id=\"ewz1665702628443__p_d105815e1_d105816e1_d105817e1\">If you set the <code class=\"ph codeph\">Cursor</code> property\n            with <span class=\"keyword cmdname\">$properties</span>, every occurrence of the field shows the same\n            cursor. If you set it with <span class=\"keyword cmdname\">$fieldproperties</span>, the cursor is shown only\n            on the field in the current occurrence.</p>\n<p class=\"p\" id=\"ewz1665702628443__p_d105818e1_d105819e1_d105820e1\">To ensure that the desired occurrence is the\n            current one, use <span class=\"keyword cmdname\">setocc</span> prior to <span class=\"keyword cmdname\">$fieldproperties</span>,\n            for example during initialization (when retrieving data) or when the user performs an\n            action (such as clicking a button). <span class=\"keyword cmdname\">setocc</span> does not switch the focus,\n            so no triggers are fired, which could interfere with displaying mouse cursors.</p>\n</section>\n<section class=\"section\" id=\"ewz1665702628443__section_n1b_cbd_zwb\"><h2 class=\"title sectiontitle\" id=\"d1161870e583\">Applies To</h2>\n<ul class=\"ul\" id=\"ewz1665702628443__ul_q5n_cbd_zwb\">\n<li class=\"li\" id=\"ewz1665702628443__li_d42011e1_d42012e1_d42013e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105824e1_d105825e1_d105826e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"fxi1688449052174.html\" href=\"/de-DE/bundle/uniface_104/page/fxi1688449052174.html\" title=\"The ucheckbox widget enables the user to set a Boolean value in a form component. Uniface provides a logical widget called CheckBox, which is mapped to ucheckbox.\">ucheckbox (CheckBox)</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42014e1_d42015e1_d42016e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105827e1_d105828e1_d105829e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"zfr1695290811319.html\" href=\"/de-DE/bundle/uniface_104/page/zfr1695290811319.html\" title=\"Start the Microsoft Windows Color dialog box.\">colorbox</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42017e1_d42018e1_d42019e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105830e1_d105831e1_d105832e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"jrc1665702631553.html\" href=\"/de-DE/bundle/uniface_104/page/jrc1665702631553.html\" title=\"The CommandButton is a logical widget that enables a user to initiate an action by clicking the button.\">CommandButton</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42020e1_d42021e1_d42022e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105833e1_d105834e1_d105835e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"fud1688450548955.html\" href=\"/de-DE/bundle/uniface_104/page/fud1688450548955.html\" title=\"The udropdownlist widget is a field-level widget that can display a list of valid options in a list below the input field, so that the user can select one. It is applicable only to form components.\">udropdownlist (DropDownList)</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42023e1_d42024e1_d42025e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105836e1_d105837e1_d105838e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"klb1688454363706.html\" href=\"/de-DE/bundle/uniface_104/page/klb1688454363706.html\" title=\"Default logical widget for entering and displaying data in a field in a Form or Report.\">EditBox</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42026e1_d42027e1_d42028e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105839e1_d105840e1_d105841e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"rgn1665702634165.html\" href=\"/de-DE/bundle/uniface_104/page/rgn1665702634165.html\" title=\"Image to use as the background image on the map widget.\">Image Name</a>\n</p>\n</li>\n<li class=\"li\" id=\"ewz1665702628443__li_d42029e1_d42030e1_d42031e1\">\n<p class=\"p\" id=\"ewz1665702628443__p_d105842e1_d105843e1_d105844e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"lxs1665702651483.html\" href=\"/de-DE/bundle/uniface_104/page/lxs1665702651483.html\" title=\"The uspinbutton widget enables the user to enter or select a numeric value by clicking a button to increase or decrease a value by a predefined interval within a predefined range. Uniface provides a logical widget called SpinButton, which is mapped to uspinbutton.\">uspinbutton (SpinButton)</a>\n</p>\n</li>\n</ul>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3612925\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3612925\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Mouse Pointer ( Cursor) Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 10, 2024 Summarize Uniface 10.4 Mouse Pointer ( Cursor) Image used when the mouse pointer is positioned over the widget. The default depends on the widget. \" Cursor = CursorName \" CursorName Representation Description UAppStarting Standard arrow and small hourglass UArrow Standard arrow UCrosshair Crosshair UHand Hand UHelp Arrow and question mark UIBeam I-beam UNo Slashed circle USizeAll Four-pointed arrow pointing north, south, east, and west USizeNESW Double-pointed arrow pointing northeast and southwest USizeNS Double-pointed arrow pointing north and south USizeNWSE Double-pointed arrow pointing northwest and southeast USizeWE Double-pointed arrow pointing west and east UUpArrow Vertical arrow UWait Hourglass Description Specifies the system cursor image to be used on mouse roll-over, that is, when the mouse pointer is positioned over the widget. Setting in ProcScript You can set the value of the Cursor property in ProcScript using the $properties or $fieldproperties functions, for example: $fieldproperties(EDITFIELD)=\"cursor=uarrow\" Copy If you set the Cursor property with $properties , every occurrence of the field shows the same cursor. If you set it with $fieldproperties , the cursor is shown only on the field in the current occurrence. To ensure that the desired occurrence is the current one, use setocc prior to $fieldproperties , for example during initialization (when retrieving data) or when the user performs an action (such as clicking a button). setocc does not switch the focus, so no triggers are fired, which could interfere with displaying mouse cursors. Applies To ucheckbox (CheckBox) colorbox CommandButton udropdownlist (DropDownList) EditBox Image Name uspinbutton (SpinButton) Was this topic helpful? Like Dislike"}