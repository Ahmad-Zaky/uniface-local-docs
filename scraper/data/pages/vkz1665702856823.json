{"id": "vkz1665702856823", "title": "Type Conversion Rules", "breadcrumbs": ["Scripting Application Behavior", "Data Handling in ProcScript", "Type Conversion", "Type Conversion Rules"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/vkz1665702856823.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Type Conversion Rules</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:  Type Conversion   \" class=\"\" data-tooltip-content=\"Previous:  Type Conversion   \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/hju1665702578520.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:   Implicit Type Conversion \" class=\"\" data-tooltip-content=\"Next:   Implicit Type Conversion \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/snj1665702856894.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg>Add to My Topics</span><div aria-labelledby=\"pdfDropdown\" class=\"dropdown-menu dropdown-menu-right\"><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/vkz1665702856823.html?finish_action=mydocs_topic_and_sub\">Add selected topic and subtopics</a><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/vkz1665702856823.html?finish_action=mydocs_topic_and_sub_head\">Add Topic &amp; Subtopics with topic head</a><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/vkz1665702856823.html?finish_action=mydocs_pub\">Add entire publication</a></div></div><div class=\"zDocsWatchButton\" role=\"listitem\"><span aria-label=\"Watch\" class=\"d-lg-flex d-none zDocsSubscribeButton\" data-tooltip-content=\"Watch\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-eye\"><use xlink:href=\"#ico-eye\"></use></svg></span><span class=\"d-lg-none d-flex zDocsSubscribeButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-eye zDocsSubscribeButton\"><use xlink:href=\"#ico-eye\"></use></svg><span class=\"zDocsSubscribeButton\">Watch</span></span></div><div class=\"zDocsExportPdfMenu zDocsExportMenu\" data-testid=\"export-pdf-menu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Download PDF\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Download PDF\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-pdf\"><use xlink:href=\"#ico-pdf\"></use></svg></span><span class=\"d-lg-none d-flex\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#ZdExportPDFModal\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-pdf\"><use xlink:href=\"#ico-pdf\"></use>