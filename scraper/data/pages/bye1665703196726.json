downMenu\"><a class=\"zDocsExportItem zDocsExportTopicButton\" href=\"#\" id=\"singlePdf\" role=\"button\">Save selected topic</a><a class=\"zDocsExportItem zDocsExportSubtopicsButton\" href=\"#\" id=\"pdfWithChildren\" role=\"button\">Save selected topic and subtopics</a><a class=\"zDocsExportItem zDocsExportBundleButton\" href=\"#\" id=\"wholeBundlePdf\" role=\"button\">Save entire publication</a></div></div><div class=\"zDocsTopicShare zDocsShareButton\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Share\" class=\"d-none d-lg-flex zDocsShareDialogButton\" data-toggle=\"dropdown\" data-tooltip-content=\"Share\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg></span><span class=\"d-lg-none zDocsShareDialogButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg>Share</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"dropdown-item zDocsShareButton zDocsShareEmail\" href=\"#\" role=\"button\"><span>Email Link</span></a><a class=\"dropdown-item zDocsShareButton zDocsShareLink\" href=\"#\" role=\"button\"><span>Copy Link</span></a></div></div><div class=\"zDocsFeedback zDocsFeedback zDocsTopicFeedback\" role=\"listitem\"><span aria-label=\"Feedback\" class=\"zDocsFeedbackButton d-none d-lg-flex\" data-backdrop=\"static\" data-target=\"#feedbackModal_main_2526305\" data-toggle=\"modal\" data-tooltip-content=\"Feedback\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg></span><span class=\"d-lg-none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_2526305\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Jan 22, 2023</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104bye1665703196726.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/bye1665703196726.html\" id=\"bundle:uniface_104/enus/bye1665703196726.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"bye1665703196726\" role=\"article\">\n<div class=\"body conbody\"><p class=\"shortdesc\">Stop one or more Uniface Servers.</p>\n<section class=\"section refsyn\" id=\"bye1665703196726__section_bw1_tzk_gwb\">\n<p class=\"lines\" id=\"bye1665703196726__lines_sqh_tzk_gwb\"><code class=\"ph codeph\">operation STOP_SERVERS</code><br/><code class=\"ph codeph\">params</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">Srvid</var> <code class=\"ph codeph\">: IN ; (I4)</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">Using</var> <code class=\"ph codeph\">: IN ; (C1)</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">Host</var> <code class=\"ph codeph\">: IN ; (C80)</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">User</var> <code class=\"ph codeph\">: IN ; (C40)</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">UST</var> <code class=\"ph codeph\">: IN ; (C20)</code><br/><code class=\"ph codeph\"> string</code> <var class=\"keyword varname\">Mode</var> <code class=\"ph codeph\">: IN ; (C1)</code><br/><code class=\"ph codeph\">endparams</code></p>\n</section>\n<section class=\"section\" id=\"bye1665703196726__section_o1q_11l_gwb\"><h2 class=\"title sectiontitle\" id=\"d1242797e120\">Parameters</h2>\n<ul class=\"ul\" id=\"bye1665703196726__ul_qnl_c1l_gwb\">\n<li class=\"li\">\n<var class=\"keyword varname\">Srvid</var>—ID of the single server to be stopped, if specified.\n</li>\n<li class=\"li\">\n<var class=\"keyword varname\">Using</var>—type of server, if specified. One of: <ul class=\"ul\" id=\"bye1665703196726__ul_snl_c1l_gwb\">\n<li class=\"li\">\n<code class=\"ph codeph\">S</code>—server with the specified host name, UST, and/or user name\n        </li>\n<li class=\"li\">\n<code class=\"ph codeph\">C</code>—server used by clients with the specified host name, UST, and/or\n            user name\n        </li>\n</ul>\n</li>\n<li class=\"li\">\n<var class=\"keyword varname\">Host</var>—host name of the client or server\n</li>\n<li class=\"li\">\n<var class=\"keyword varname\">User</var>—user name of the client or server\n</li>\n<li class=\"li\">\n<var class=\"keyword varname\">UST</var>—Uniface Server Type (UST) of the client or server\n</li>\n<li class=\"li\">\n<var class=\"keyword varname\">Mode</var>—stop-mode; one of: <code class=\"ph codeph\">F</code> for forced or\n            <code class=\"ph codeph\">N</code> for normal. <p class=\"p\">In forced mode, servers are stopped immediately and\n            clients are disconnected. In normal mode, existing clients are allowed to deliver\n            requests to servers until the server reports it has no state, that is, it has no locks\n            and no context (active component instances). At that moment, the server is stopped.</p>\n</li>\n</ul>\n<p class=\"p\">The selection criteria <var class=\"keyword varname\">Host</var>, <var class=\"keyword varname\">User</var> and/or\n          <var class=\"keyword varname\">UST</var>, if present, are combined (using logical AND) and applied to\n        running servers or clients, to select the servers to be stopped.</p>\n<p class=\"p\">This operation returns once the request is posted to the Uniface Router. This operation\n        might fail if the servers were already flagged as stopping at an equal or higher mode.</p>\n</section>\n<section class=\"section\" id=\"bye1665703196726__section_fqt_p1l_gwb\"><h2 class=\"title sectiontitle\" id=\"d1242797e205\">Return Values</h2>\n<p class=\"p\" id=\"bye1665703196726__p_d134921e1_d134922e1_d134923e1\">If successful, <span class=\"keyword cmdname\">$status</span> is set to 0.\n        Otherwise, see <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qln1665702528769.html\" href=\"/de-DE/bundle/uniface_104/page/qln1665702528769.html#qln1665702528769__section_fbt_4d2_gwb\">Return Codes</a>.</p>\n</section>\n<section class=\"section\" id=\"bye1665703196726__section_pjw_q1l_gwb\"><h2 class=\"title sectiontitle\" id=\"d1242797e221\">Use</h2>\n<p class=\"p\">Allowed in all Uniface component types.</p>\n</section>\n<section class=\"section\" id=\"bye1665703196726__section_qn4_r1l_gwb\"><h2 class=\"title sectiontitle\" id=\"d1242797e230\">Description</h2>\n<p class=\"p\">The privileged-user operation <span class=\"keyword apiname\">STOP_SERVERS</span> stops a single server with\n        the specified <var class=\"keyword varname\">Srvid</var>, or stops multiple servers identified by the\n        specified <var class=\"keyword varname\">Host</var>, <var class=\"keyword varname\">User</var>, and/or\n        <var class=\"keyword varname\">UST</var>.</p>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526305\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2526305\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "STOP_SERVERS Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Jan 22, 2023 Summarize Uniface 10.4 Stop one or more Uniface Servers. operation STOP_SERVERS params string Srvid : IN ; (I4) string Using : IN ; (C1) string Host : IN ; (C80) string User : IN ; (C40) string UST : IN ; (C20) string Mode : IN ; (C1) endparams Parameters Srvid —ID of the single server to be stopped, if specified. Using —type of server, if specified. One of: S —server with the specified host name, UST, and/or user name C —server used by clients with the specified host name, UST, and/or user name Host —host name of the client or server User —user name of the client or server UST —Uniface Server Type (UST) of the client or server Mode —stop-mode; one of: F for forced or N for normal. In forced mode, servers are stopped immediately and clients are disconnected. In normal mode, existing clients are allowed to deliver requests to servers until the server reports it has no state, that is, it has no locks and no context (active component instances). At that moment, the server is stopped. The selection criteria Host , User and/or UST , if present, are combined (using logical AND) and applied to running servers or clients, to select the servers to be stopped. This operation returns once the request is posted to the Uniface Router. This operation might fail if the servers were already flagged as stopping at an equal or higher mode. Return Values If successful, $status is set to 0. Otherwise, see Return Codes . Use Allowed in all Uniface component types. Description The privileged-user operation STOP_SERVERS stops a single server with the specified Srvid , or stops multiple servers identified by the specified Host , User , and/or UST . Was this topic helpful? Like Dislike"}