dyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104sdu1665702974089.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/sdu1665702974089.html\" id=\"bundle:uniface_104/enus/sdu1665702974089.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"sdu1665702974089\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Working with Sybase\n </h1>\n<div class=\"body conbody\" id=\"sdu1665702974089__working_with_sybase_176574\"><p class=\"shortdesc\">\n</p>\n<section class=\"section context\" id=\"sdu1665702974089__topic_d61253e1_d61254e1_d61255e1\">\n<p class=\"p\" id=\"sdu1665702974089__p_d61256e1_d61257e1_d61258e1\">To use databases, you often have to change your system setup so that the connectors you require are ready for use. This can involve installing, configuring, converting, binding, migrating, and upgrading so that the connectors meet your requirements.</p>\n</section>\n<section class=\"section ul\">\n<ul class=\"ul\">\n<li class=\"li\" id=\"sdu1665702974089__li_d26903e1_d26904e1_d26905e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"wto1665702974164.html\" href=\"/de-DE/bundle/uniface_104/page/wto1665702974164.html\" title=\"The suffix used in modeled entity names can be used to group entities into a logical group.\">Create Tables for Modeled Entities</a>\n</li>\n<li class=\"li\" id=\"sdu1665702974089__li_d26906e1_d26907e1_d26908e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"prg1665702974232.html\" href=\"/de-DE/bundle/uniface_104/page/prg1665702974232.html\" title=\"Back up the data before installing the SYB connector.\">Back Up the Data</a>\n</li>\n<li class=\"li\" id=\"sdu1665702974089__li_d26909e1_d26910e1_d26911e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"glt1665702968317.html\" href=\"/de-DE/bundle/uniface_104/page/glt1665702968317.html\">Set the Sybase Packet Size</a>\n</li>\n<li class=\"li\" id=\"sdu1665702974089__li_d26912e1_d26913e1_d26914e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bko1665702974302.html\" href=\"/de-DE/bundle/uniface_104/page/bko1665702974302.html\">Upgrade to Row-Level, Data Pages, and All Pages Locking</a>\n</li>\n<li class=\"li\" id=\"sdu1665702974089__li_d26915e1_d26916e1_d26917e1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bpx1665702974375.html\" href=\"/de-DE/bundle/uniface_104/page/bpx1665702974375.html\">Use Row-Level, Data Pages, and All Pages Locking</a>\n</li>\n</ul>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2531930\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2531930\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", 