ropdownMenu\"><a class=\"zDocsExportItem zDocsExportTopicButton\" href=\"#\" id=\"singlePdf\" role=\"button\">Save selected topic</a><a class=\"zDocsExportItem zDocsExportSubtopicsButton\" href=\"#\" id=\"pdfWithChildren\" role=\"button\">Save selected topic and subtopics</a><a class=\"zDocsExportItem zDocsExportBundleButton\" href=\"#\" id=\"wholeBundlePdf\" role=\"button\">Save entire publication</a></div></div><div class=\"zDocsTopicShare zDocsShareButton\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Share\" class=\"d-none d-lg-flex zDocsShareDialogButton\" data-toggle=\"dropdown\" data-tooltip-content=\"Share\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg></span><span class=\"d-lg-none zDocsShareDialogButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg>Share</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"dropdown-item zDocsShareButton zDocsShareEmail\" href=\"#\" role=\"button\"><span>Email Link</span></a><a class=\"dropdown-item zDocsShareButton zDocsShareLink\" href=\"#\" role=\"button\"><span>Copy Link</span></a></div></div><div class=\"zDocsFeedback zDocsFeedback zDocsTopicFeedback\" role=\"listitem\"><span aria-label=\"Feedback\" class=\"zDocsFeedbackButton d-none d-lg-flex\" data-backdrop=\"static\" data-target=\"#feedbackModal_main_2531293\" data-toggle=\"modal\" data-tooltip-content=\"Feedback\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg></span><span class=\"d-lg-none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_2531293\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Okt 21, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104qjp1665702722983.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/qjp1665702722983.html\" id=\"bundle:uniface_104/enus/qjp1665702722983.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"qjp1665702722983\" role=\"article\">\n<div class=\"body conbody\"><p class=\"shortdesc\">Determines how the ticks part of date and date time fields is handled.\n </p>\n<section class=\"section refsyn\" id=\"qjp1665702722983__topic_d142139e1_d142140e1_d142141e1\">\n<p class=\"p\" id=\"qjp1665702722983__p_d142142e1_d142143e1_d142144e1\">\n<span class=\"keyword cmdname\">$NO_TICKS</span> { <code class=\"ph codeph\">=</code> } {<code class=\"ph codeph\">true</code> | <code class=\"ph codeph\">false</code>}</p>\n</section>\n<section class=\"section\" id=\"qjp1665702722983__section_olj_w1v_jwb\"><h2 class=\"title sectiontitle\" id=\"d241468e68\">Arguments</h2>\n<ul class=\"ul\" id=\"qjp1665702722983__ul_gnr_x1v_jwb\">\n<li class=\"li\" id=\"qjp1665702722983__li_d50078e1_d50079e1_d50080e1\"><code class=\"ph codeph\">true</code>—sets the ticks part of time\n               and datetime database fields to 0 when such a field is assigned a value in\n               ProcScript. Applies to the following packing codes: <ul class=\"ul\" id=\"qjp1665702722983__ul_hnr_x1v_jwb\">\n<li class=\"li\" id=\"qjp1665702722983__li_d50081e1_d50082e1_d50083e1\">T1, T2, T3, T4, E3, E4, E5, E6, E8, E10,\n                     E11—the entire ticks segment is set to 0. </li>\n<li class=\"li\" id=\"qjp1665702722983__li_d50084e1_d50085e1_d50086e1\">T5, E12—the 100th part is set to 0, but not\n                     the 10th, because these packing codes are defined as having one extra digit\n                     after the second. </li>\n</ul>\n<p class=\"p\" id=\"qjp1665702722983__p_d142148e1_d142149e1_d142150e1\">The other T and E packing codes are not\n                  affected, because they are defined as supporting ticks.</p>\n</li>\n<li class=\"li\" id=\"qjp1665702722983__li_d50087e1_d50088e1_d50089e1\"><code class=\"ph codeph\">false</code>—sets the ticks.</li>\n</ul>\n</section>\n<section class=\"section\" id=\"qjp1665702722983__section_yf2_z1v_jwb\"><h2 class=\"title sectiontitle\" id=\"d241468e99\">Defaults</h2>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"qjp1665702722983__table_d17048e1_d17049e1_d17050e1\"><caption></caption><colgroup><col/><col/></colgroup><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\">Assignment file: </td>\n<td class=\"entry\" dir=\"ltr\">client assignment files </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\">Section: </td>\n<td class=\"entry\" dir=\"ltr\">[SETTINGS] </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\">Default value: </td>\n<td class=\"entry\" dir=\"ltr\">False </td>\n</tr>\n</tbody></table></div>\n</section>\n<section class=\"section\" id=\"qjp1665702722983__section_y3v_bbv_jwb\"><h2 class=\"title sectiontitle\" id=\"d241468e145\">Description</h2>\n<p class=\"p\" id=\"qjp1665702722983__p_d142157e1_d142158e1_d142159e1\">Since Uniface 9.2, Uniface stores the ticks in time\n            and datetime fields. In previous versions, the tick part of these fields was set to 0.\n            This can cause incompatible behavior in existing applications.</p>\n<p class=\"p\" id=\"qjp1665702722983__p_d142160e1_d142161e1_d142162e1\">Use this switch if you want the pre-9.2 behavior\n            for time and datetime fields.</p>\n</section>\n</div>\n</article></main></article>\n</div></div><div class=\"contentPlaceholder\" style=\"height: 500px;\"><div class=\"contentContainer zDocsSideBoxes\"><div><h5 aria-level=\"5\" class=\"css-g931ng\">Related Links</h5><ul><li><a class=\"css-ettsdk\" href=\"/de-DE/bundle/uniface_104/page/nbc1665702757240.html\" stylesprops=\"[object Object]\"><svg aria-hidden=\"true\" class=\"ico-related-link\"><use xlink:href=\"#ico-related-link\"></use></svg>Packing Codes for Date and Time Data</a><p>Uniface data types Date, Time, and Datetime (and linear variations of these) are associated with a variety of packing codes.</p></li></ul></div></div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2531293\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2531293\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "$NO_TICKS Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 21, 2024 Summarize Uniface 10.4 Determines how the ticks part of date and date time fields is handled. $NO_TICKS { = } { true | false } Arguments true —sets the ticks part of time and datetime database fields to 0 when such a field is assigned a value in ProcScript. Applies to the following packing codes: T1, T2, T3, T4, E3, E4, E5, E6, E8, E10, E11—the entire ticks segment is set to 0. T5, E12—the 100th part is set to 0, but not the 10th, because these packing codes are defined as having one extra digit after the second. The other T and E packing codes are not affected, because they are defined as supporting ticks. false —sets the ticks. Defaults Assignment file: client assignment files Section: [SETTINGS] Default value: False Description Since Uniface 9.2, Uniface stores the ticks in time and datetime fields. In previous versions, the tick part of these fields was set to 0. This can cause incompatible behavior in existing applications. Use this switch if you want the pre-9.2 behavior for time and datetime fields. Related Links Packing Codes for Date and Time Data Uniface data types Date, Time, and Datetime (and linear variations of these) are associated with a variety of packing codes. Was this topic helpful? Like Dislike"}