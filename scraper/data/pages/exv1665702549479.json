{"id": "exv1665702549479", "title": "/ini", "breadcrumbs": ["Uniface Reference", "Command Line Switches Reference", "/ini"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/exv1665702549479.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">/ini</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:   /inf \" class=\"\" data-tooltip-content=\"Previous:   /inf \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/czj1665702653450.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:  /inst  \" class=\"\" data-tooltip-content=\"Next:  /inst  \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/cle1665702738757.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg>Add to My Topics</span><div aria-labelledby=\"pdfDropdown\" class=\"dropdown-menu dropdown-menu-right\"><a class=\"zDocsAddTopicButton zDocsMyDocsMenuIte