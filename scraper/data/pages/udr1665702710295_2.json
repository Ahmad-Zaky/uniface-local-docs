\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__2\">\n<p class=\"p\">Code page 1255 for Hebrew</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__3\">\n<p class=\"p\">Windows</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">IBM PC 1256</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__2\">\n<p class=\"p\">Code page 1256 for Arabic</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__3\">\n<p class=\"p\">Windows</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">IBM EBCDIC</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__2\">\n<p class=\"p\">CCSID code page appropriate to the platform</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__3\">\n<p class=\"p\">OS/400, z/OS</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">Shift-JIS</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__2\">\n<p class=\"p\">Japanese character set Shift-JIS ( code page 932 and 943)</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"udr1665702710295__table_d11144e1_d11145e1_d11146e1__entry__3\">\n<p class=\"p\">Windows, Unix</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" head