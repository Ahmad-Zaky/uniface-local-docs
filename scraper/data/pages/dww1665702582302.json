zDocsDropdownMenu\"><a class=\"zDocsExportItem zDocsExportTopicButton\" href=\"#\" id=\"singlePdf\" role=\"button\">Save selected topic</a><a class=\"zDocsExportItem zDocsExportSubtopicsButton\" href=\"#\" id=\"pdfWithChildren\" role=\"button\">Save selected topic and subtopics</a><a class=\"zDocsExportItem zDocsExportBundleButton\" href=\"#\" id=\"wholeBundlePdf\" role=\"button\">Save entire publication</a></div></div><div class=\"zDocsTopicShare zDocsShareButton\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Share\" class=\"d-none d-lg-flex zDocsShareDialogButton\" data-toggle=\"dropdown\" data-tooltip-content=\"Share\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg></span><span class=\"d-lg-none zDocsShareDialogButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-share\"><use xlink:href=\"#ico-share\"></use></svg>Share</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"dropdown-item zDocsShareButton zDocsShareEmail\" href=\"#\" role=\"button\"><span>Email Link</span></a><a class=\"dropdown-item zDocsShareButton zDocsShareLink\" href=\"#\" role=\"button\"><span>Copy Link</span></a></div></div><div class=\"zDocsFeedback zDocsFeedback zDocsTopicFeedback\" role=\"listitem\"><span aria-label=\"Feedback\" class=\"zDocsFeedbackButton d-none d-lg-flex\" data-backdrop=\"static\" data-target=\"#feedbackModal_main_3612690\" data-toggle=\"modal\" data-tooltip-content=\"Feedback\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg></span><span class=\"d-lg-none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_3612690\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"