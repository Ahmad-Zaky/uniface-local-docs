odal_main_3616769\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Okt 10, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104wnw1665702638181.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/wnw1665702638181.html\" id=\"bundle:uniface_104/enus/wnw1665702638181.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"wnw1665702638181\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Dynamic Label (\n                              Label)\n </h1>\n<div class=\"body conbody\"><p class=\"shortdesc\">Indicates whether the associated label for the widget's field is updated dynamically to reflect the object contained in the widget.\n </p>\n<p class=\"p\" id=\"wnw1665702638181__p_d103277e1_d103278e1_d103279e1\">Label<code class=\"ph codeph\">=</code><code class=\"ph codeph\">\"</code><code class=\"ph codeph\">True</code> | <code class=\"ph codeph defvalue\">False</code><code class=\"ph codeph\">\"</code></p>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1\"><caption></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__1\">\n<p class=\"p\">Value</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__2\">\n<p class=\"p\">Description</p>\n</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph\">True</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__2\">\n<p class=\"p\">The contents of the widget's second subfield are automatically displayed in its associated label (if the label exists).</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__1\">\n<p class=\"p\">\n<code class=\"ph codeph defvalue\">False</code>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"wnw1665702638181__table_d12179e1_d12180e1_d12181e1__entry__2\">\n<p class=\"p\">The label is not dynamically updated.</p>\n</td>\n</tr>\n</tbody></table></div>\n<section class=\"section\" id=\"wnw1665702638181__section_c1s_ng3_wwb\"><h2 class=\"title sectiontitle\" id=\"d800181e135\">Description</h2>\n<p class=\"p\" id=\"wnw1665702638181__p_d103283e1_d103284e1_d103285e1\">For example, if <code class=\"ph codeph\">True</code>, the\n            ProcScript <code class=\"ph codeph\">drag=1;Copy this</code> is assigned to a drag widget, where the\n               <code class=\"ph codeph\">;</code> character is a subfield separator. In this case, the value\n               <code class=\"ph codeph\">1</code> (the first subfield) is assigned to the widget named\n               <code class=\"ph codeph\">drag</code>, and the text <code class=\"ph codeph\">Copy this</code> (the second subfield)\n            is assigned to the associated dynamic label of the widget.</p>\n</section>\n<section class=\"section\" id=\"wnw1665702638181__section_km5_4g3_wwb\"><h2 class=\"title sectiontitle\" id=\"d800181e163\">Example: Setting in ProcScript</h2>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" id=\"wnw1665702638181__pre_w33_qg3_wwb\" tabindex=\"0\"><code class=\"language-plaintext\">$fieldproperties(DDFLD) = \"label=true\"</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</section>\n<section class=\"section\" id=\"wnw1665702638181__section_w4m_qg3_wwb\"><h2 class=\"title sectiontitle\" id=\"d800181e171\">Applies To</h2><a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"wrn1665702633674.html\" href=\"/de-DE/bundle/uniface_104/page/wrn1665702633674.html\" title=\"The DropTarget logical widget accepts input dragged from a DragSource, other Uniface application, or Microsoft Windows Explorer. The data that is transferred consists of a Uniface list.\">DropTarget</a></section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3616769\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3616769\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Dynamic Label ( Label) Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 10, 2024 Summarize Uniface 10.4 Dynamic Label ( Label) Indicates whether the associated label for the widget's field is updated dynamically to reflect the object contained in the widget. Label = \" True | False \" Value Description True The contents of the widget's second subfield are automatically displayed in its associated label (if the label exists). False The label is not dynamically updated. Description For example, if True , the ProcScript drag=1;Copy this is assigned to a drag widget, where the ; character is a subfield separator. In this case, the value 1 (the first subfield) is assigned to the widget named drag , and the text Copy this (the second subfield) is assigned to the associated dynamic label of the widget. Example: Setting in ProcScript $fieldproperties(DDFLD) = \"label=true\" Copy Applies To DropTarget Was this topic helpful? Like Dislike"}