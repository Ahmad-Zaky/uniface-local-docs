3125799922.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/bsx1723125799922.html\" id=\"bundle:uniface_104/enus/bsx1723125799922.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"cpq1665702733980\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      create db\n </h1>\n<div class=\"body conbody\" id=\"cpq1665702733980__create_db_144878\"><p class=\"shortdesc\">If the database file does not yet exist, creates a database file in the path specified by the connector setting.\n </p>\n<p class=\"p\" id=\"cpq1665702733980__p_d47588e1_d47589e1_d47590e1\">\n<code class=\"ph codeph\">USYS$Mnmemonic_PARAMScreate db=\n                        <code class=\"ph codeph\">on</code>\n                       | \n                        <code class=\"ph codeph defvalue\">off</code>\n</code>\n</p>\n<section class=\"section\" id=\"cpq1665702733980__topic_d31077e1_d31078e1_d31079e1_d31080e1_d31081e1\"><h2 class=\"title sectiontitle\" id=\"d932230e65\">\n                        \n Use\n </h2>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"3\" id=\"cpq1665702733980__table_d4481e1_d4482e1_d4483e1\"><caption></caption><colgroup><col/><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"cpq1665702733980__table_d4481e1_d4482e1_d4483e1__entry__1\">\n<p class=\"p\">Applies to</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"cpq1665702733980__table_d4481e1_d4482e1_d4483e1__entry__2\">\n<p class=\"p\">Mnemonic</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"cpq1665702733980__table_d4481e1_d4482e1_d4483e1__entry__3\">\n<p class=\"p\">Connector Syntax</p>\n</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"cpq1665702733980__table_d4481e1_d4482e1_d4483e1__entry__1\">\n<p class=\"p\">SQLite connector</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" header