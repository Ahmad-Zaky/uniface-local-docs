ical content.\" class=\"image\" id=\"xou1665702811617__image_qrq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/openfile.gif?_LANG=enus\"/>\n</figure>\n</div>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Select and open an existing component.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Save component</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content.\" id=\"xou1665702811617__fig_rrq_kbg_5cc\">\n<img alt=\"Graphical content.\" class=\"image\" id=\"xou1665702811617__image_srq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/savefile.gif?_LANG=enus\"/>\n</figure>\n</div>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Save the current component.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Add tag</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<figure class=\"fig fignone\" data-search=\"Add tag icon\" id=\"xou1665702811617__fig_trq_kbg_5cc\">\n<img alt=\"Add tag icon\" class=\"image\" id=\"xou1665702811617__image_urq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/u7_tagstd.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Add a manual tag to a trigger.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Check modified triggers</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<figure class=\"fig fignone\" data-search=\"Check modified\" id=\"xou1665702811617__fig_wrq_kbg_5cc\">\n<img alt=\"Check modified\" class=\"image\" id=\"xou1665702811617__image_xrq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/u8_checkmod.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Check syntax of modified triggers.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Check all triggers</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<figure class=\"fig fignone\" data-search=\"Check all\" id=\"xou1665702811617__fig_yrq_kbg_5cc\">\n<img alt=\"Check all\" class=\"image\" id=\"xou1665702811617__image_zrq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/u8_checkall.gif?_LANG=enus\"/>\n</figure>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Check syntax of all triggers.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Undo</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content\" id=\"xou1665702811617__fig_asq_kbg_5cc\">\n<img alt=\"Graphical content\" class=\"image\" id=\"xou1665702811617__image_bsq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/undo.gif?_LANG=enus\"/>\n</figure>\n</div>\n<p class=\"p\"><span class=\"ph uicontrol\">Ctrl</span>+<span class=\"ph uicontrol\">Z</span>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Undo the most recent action, up to a maximum of 16 actions.</p>\n<div class=\"note note note_note\" id=\"xou1665702811617__note_fsq_kbg_5cc\"><span class=\"note__title\">Note:</span> It is not possible to undo typing\n                           that is immediately followed by a carriage return.</div>\n<p class=\"p\">Undo moves the cursor to the place affected by the action. The ProcScript\n                           may shift slightly when this happens.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Redo</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content\" id=\"xou1665702811617__fig_gsq_kbg_5cc\">\n<img alt=\"Graphical content\" class=\"image\" id=\"xou1665702811617__image_hsq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/redo.gif?_LANG=enus\"/>\n</figure>\n</div>\n<p class=\"p\"><span class=\"ph uicontrol\">Ctrl</span>+<span class=\"ph uicontrol\">Y</span>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Redo the most recently undone action.</p>\n<p class=\"p\">You cannot undo an action that has been redone.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Cut</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<p class=\"p\"><span class=\"ph uicontrol\">Ctrl</span>+<span class=\"ph uicontrol\">X</span>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Cut the currently selected item.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Copy</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<p class=\"p\"><span class=\"ph uicontrol\">Ctrl</span>+<span class=\"ph uicontrol\">C</span>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Copy the currently selected item.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Paste</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<p class=\"p\"><span class=\"ph uicontrol\">Ctrl</span>+<span class=\"ph uicontrol\">V</span>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Paste the previously cut or copied item.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Replace spaces</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content\" id=\"xou1665702811617__fig_qsq_kbg_5cc\">\n<img alt=\"Graphical content\" class=\"image\" id=\"xou1665702811617__image_rsq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/replacespacesbytabs.gif?_LANG=enus\"/>\n</figure>\n</div>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Replace spaces by tabs in the selected text.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Replace tabs</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content\" id=\"xou1665702811617__fig_ssq_kbg_5cc\">\n<img alt=\"Graphical content\" class=\"image\" id=\"xou1665702811617__image_tsq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/replacetabsbyspaces.gif?_LANG=enus\"/>\n</figure>\n</div>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Replace tabs by spaces in the selected text.</p>\n</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Increase Indent</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" data-search=\"Graphical content\" id=\"xou1665702811617__fig_vsq_kbg_5cc\">\n<img alt=\"Graphical content\" class=\"image\" id=\"xou1665702811617__image_wsq_kbg_5cc\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/indent.gif?_LANG=enus\"/>\n</figure>\n</div>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__3\">\n<p class=\"p\">Increase the indent of the selected text.</p>\n</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__1\">\n<p class=\"p\">Decrease Indent</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"xou1665702811617__table_d596e1_d597e1_d598e1__entry__2\">\n<div class=\"p\">\n<figure class=\"fig fignone\" 