__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Char</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">TEXT</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Char</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">TEXT</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">U*</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Varchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">TEXT</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Varchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">TEXT</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">VC1-VC*</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Varchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">TEXT</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Varchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">TEXT</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">VR1-VR*</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">BLOB</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">BLOB</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">VWn</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">wvarchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">TEXT</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">nvarchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">TEXT</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">VW*</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">BLOB</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">BLOB</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">Wn</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">wchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">TEXT</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">nchar</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">TEXT</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">W*</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">BLOB</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">BLOB</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">Y1-Y32</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Binary</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">BLOB</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">BLOB</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1\">Z1-Z8</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__4\">Binary</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__5\">BLOB</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__6\">Blob</td>\n<td class=\"entry\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__7\">BLOB</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" colspan=\"5\" headers=\"lcw1665702762871__table_ult_m2h_3vb__entry__1 lcw1665702762871__table_ult_m2h_3vb__entry__2 lcw1665702762871__table_ult_m2h_3vb__entry__3 lcw1665702762871__table_ult_m2h_3vb__entry__4 lcw1665702762871__table_ult_m2h_3vb__entry__5 lcw1665702762871__table_ult_m2h_3vb__entry__6 lcw1665702762871__table_ult_m2h_3vb__entry__7\">\n<div class=\"note note note_note\" id=\"lcw1665702762871__note_yp2_vkv_jcc\"><span class=\"note__title\">Note:</span> Where an <code class=\"ph codeph\">n</code> or <code class=\"ph codeph\">m</code>\n                        is used, you need to substitute that with a number.</div>\n</td>\n</tr>\n</tbody></table></div>\n<section class=\"section\" id=\"lcw1665702762871__topic_d39102e1_d39103e1_d39104e1_d39105e1_d39106e1\"><h2 class=\"title sectiontitle\" id=\"d599732e905\">\n                        \n Overflow Tables\n </h2>\n<p class=\"p\" id=\"lcw1665702762871__p_d58955e1_d58956e1_d58957e1\">The following Uniface packing codes require an overflow table when the amount of data to be inserted into the field exceeds 8192 bytes:</p>\n<ul class=\"ul\">\n<li class=\"li\" id=\"lcw1665702762871__li_d26402e1_d26403e1_d26404e1\">(V)C*\n </li>\n<li class=\"li\" id=\"lcw1665702762871__li_d26405e1_d26406e1_d26407e1\">(V)W*\n </li>\n<li class=\"li\" id=\"lcw1665702762871__li_d26408e1_d26409e1_d26410e1\">(V)U*\n </li>\n<li class=\"li\" id=\"lcw1665702762871__li_d26411e1_d26412e1_d26413e1\">(V)R*\n </li>\n</ul>\n</section>\n<section class=\"section\" id=\"lcw1665702762871__topic_d39107e1_d39108e1_d39109e1_d39110e1_d39111e1\"><h2 class=\"title sectiontitle\" id=\"d599732e929\">\n                        \n SQLite Storage Classes\n </h2>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1\"><caption><span class=\"table--title-label\">Table 2. </span><span class=\"title\">SQLite Storage Formats</span></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n Storage format\n </th>\n<th class=\"entry\" dir=\"ltr\" id=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\">\n Description\n </th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n TEXT\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\"> The TEXT storage class is used for storing\n                        fixed- and variable-size character strings, time values, date values, date\n                        time values, and ASCII boolean values (0|1, F | T, N | Y).<p class=\"p\">The database\n                           encoding is UTF-8.Time values are stored in the ASCII format\n                              <var class=\"keyword varname\">hh:nn:ss</var>.</p>\n<p class=\"p\">Date values are stored in the ASCII format\n                           <var class=\"keyword varname\">yyyy-mm-dd</var>.</p>\n<p class=\"p\">Datetime values are stored in the ASCII format <var class=\"keyword varname\">yyyy-mm-dd\n                              hh:nn:ss</var>.</p>\n<div class=\"note note note_note\" id=\"lcw1665702762871__note_w1456ab1b5b7b3b3b7b1b3c19_w1457ab1b5b7b3b3b7b1b3_w1458ab1b5b7b3b3b7b1_w1459ab1b5b7b3b3b7_w1460ab1b5b7b3b3_w1461ab1b5b7b3_w1462ab1b5b7_w1463ab1b5_w1464ab1\"><span class=\"note__title\">Note:</span> If you need to store date or dateline data that includes\n                           ticks, use the E13 or T6 packing codes.</div>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n INTEGER\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\">\n<p class=\"p\">The INTEGER storage class is used to store integer values between -264+1 and 264-1. The storage size varies from 1 to 8 bytes depending on the magnitude of the value.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n REAL\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\">\n The REAL storage class is used to store floating point values. The value is stored as an 8-byte IEEE floating point number.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n BLOB\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\">\n The BLOB storage class is used for Image data and raw binary data.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__1\">\n NULL\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lcw1665702762871__table_d5351e1_d5352e1_d5353e1__entry__2\">\n The NULL storage class is used for NULL values. For more information on NULL handling, consult the SQLite documentation.\n </td>\n</tr>\n</tbody></table></div>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529508\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529508\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "SQLite Data Packing Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Sept 30, 2024 Summarize Uniface 10.4 SQLite Data Packing The table describes how Uniface packing codes are mapped to SQLite storage formats. Table 1. Mappings Between Uniface Packing Codes and SQLite Storage Class Uniface Packing Code SLE U1.0 SLE U2.0 SQLite Typename SQLite Storage Class SQLite Typename SQLite Storage Class B Boolean integer INTEGER Boolean integer INTEGER B1-B3 Boolean text TEXT Boolean text TEXT B4-B5 Binary boolean INTEGER Boolean integer INTEGER Cn Char TEXT Char TEXT C* Varchar TEXT Varchar TEXT D, D1-D13 Date TEXT Date TEXT E, E1-12 Datetime TEXT Datetime TEXT E13 Datetime TEXT; stores ticks Datetime TEXT; stores ticks F Numeric REAL Numeric REAL F4,F8 Double Precision REAL Double Precision REAL I1-I8 Integer INTEGER Integer INTEGER J1-J18 Int INTEGER N/A N/A J19-J32 Char TEXT N/A N/A J1-32 N/A N/A Numeric INTEGER M1-M8 Money REAL Money REAL (N) Cn Numeric REAL Numeric REAL N1-16 Double precision REAL N/A N/A N17-32 Char TEXT N/A N/A N1-32 N/A N/A Numeric INTEGER O1-O18 Integer INTEGER Integer INTEGER O19-O32 Numeric TEXT Numeric TEXT P1-P8 Integer INTEGER Integer INTEGER P9-P16 Double Precision REAL Double Precision REAL Q1-Q18 Integer INTEGER Integer INTEGER Q19-Q32 Double Precision REAL Double Precision REAL Rn Binary BLOB Blob BLOB R* Varbinary BLOB Blob BLOB SC* Clob TEXT Clob TEXT SR* Blob BLOB Blob BLOB SU* Clob TEXT Clob TEXT SW* wclob TEXT nclob TEXT T, T1-T5 Time TEXT Time TEXT T6 Datetime TEXT; stores ticks Datetime TEXT; stores ticks Un Char TEXT Char TEXT U* Varchar TEXT Varchar TEXT VC1-VC* Varchar TEXT Varchar TEXT VR1-VR* Blob BLOB Blob BLOB VWn wvarchar TEXT nvarchar TEXT VW* Blob BLOB Blob BLOB Wn wchar TEXT nchar TEXT W* Blob BLOB Blob BLOB Y1-Y32 Binary BLOB Blob BLOB Z1-Z8 Binary BLOB Blob BLOB Note: Where an n or m is used, you need to substitute that with a number. Overflow Tables The following Uniface packing codes require an overflow table when the amount of data to be inserted into the field exceeds 8192 bytes: (V)C* (V)W* (V)U* (V)R* SQLite Storage Classes Table 2. SQLite Storage Formats Storage format Description TEXT The TEXT storage class is used for storing fixed- and variable-size character strings, time values, date values, date time values, and ASCII boolean values (0|1, F | T, N | Y). The database encoding is UTF-8.Time values are stored in the ASCII format hh:nn:ss . Date values are stored in the ASCII format yyyy-mm-dd . Datetime values are stored in the ASCII format yyyy-mm-dd hh:nn:ss . Note: If you need to store date or dateline data that includes ticks, use the E13 or T6 packing codes. INTEGER The INTEGER storage class is used to store integer values between -264+1 and 264-1. The storage size varies from 1 to 8 bytes depending on the magnitude of the value. REAL The REAL storage class is used to store floating point values. The value is stored as an 8-byte IEEE floating point number. BLOB The BLOB storage class is used for Image data and raw binary data. NULL The NULL storage class is used for NULL values. For more information on NULL handling, consult the SQLite documentation. Was this topic helpful? Like Dislike"}