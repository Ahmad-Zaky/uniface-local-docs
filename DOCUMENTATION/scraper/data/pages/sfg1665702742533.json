=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">Euro sign</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1250</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">Czech; Eastern Europe</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1251</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">Russian; Cyrillic</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1252</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">English and Western Europe (default)</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1253</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">Greek</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1255</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__2\">Hebrew</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"sfg1665702742533__table_d18080e1_d18081e1_d18082e1__entry__1\">\n<code class=\"ph codeph\">windows-1256</code>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"