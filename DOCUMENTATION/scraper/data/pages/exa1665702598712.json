{"id": "exa1665702598712", "title": "$curocc", "breadcrumbs": ["Uniface Reference", "ProcScript Reference", "ProcScript: Functions", "$curocc"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/exa1665702598712.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">$curocc</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:   $curline \" class=\"\" data-tooltip-content=\"Previous:   $curline \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/wmy1719769435039.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:  $curoccvideo   \" class=\"\" data-tooltip-content=\"Next:  $curoccvideo   \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/osa1718948841924.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg>Add to My Topics</span><div aria-labelledby=\"pdfDropdown\" class=\"dropdown-menu dropdown-menu-right\"><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/exa1665702598712.html?finish_action=mydocs_topic_and_sub\">Add selected topic and subtopics</a><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/exa1665702598712.html?finish_action=mydocs_topic_and_sub_head\">Add Topic &amp; Subtopics with topic head</a><a class=\"zDocsAddTopicButton zDocsMyDocsMenuItem dropdown-item\" href=\"/de-DE/auth/login?redirect=/bundle/uniface_104/page/exa1665702598712.html?finish_action=mydocs_pub\">Add entire publication</a></div></div><div class=\"zDocsWatchButton\" role=\"listitem\"><span aria-label=\"Watch\" class=\"d-lg-flex d-none zDocsSubscribeButton\" data-tooltip-content=\"Watch\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-eye\"><use xlink:href=\"#ico-eye\"></use></svg></span><span class=\"d-lg-none d-flex zDocsSubscribeButton\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-eye zDocsSubscribeButton\"><use xlink:href=\"#ico-eye\"></use></svg><span class=\"zDocsSubscribeButton\">Watch</span></span></div><div class=\"zDocsExportPdfMenu zDocsExportMenu\" data-testid=\"export-pdf-menu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Download PDF\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Download PDF\" data-tooltip-id=\"zDocsTopicActionsTooltip\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-pdf\"><use xlink:href=\"#ico-pdf\"></use></svg></span><span class=\"d-lg-none d-flex\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#ZdExportPDFModal\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-pdf\"><use xlink:href=\"#ico-pdf\"></use></svg>Download PDF</span><div class=\"dropdown-menu zDocsDropdownMenu\"><a class=\"zDocsExport