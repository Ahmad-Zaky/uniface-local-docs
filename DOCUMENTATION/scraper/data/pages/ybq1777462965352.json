entry\" id=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\">Description</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\">\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__1\">Logical widget name:</td>\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\"><code class=\"ph codeph\">ux-TimePicker</code></td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__1\">Maps to physical widget:</td>\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\"><code class=\"ph codeph\">uxTextField</code> of type time</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__1\">Default definition:</td>\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\"><code class=\"ph codeph\">ux-TimePicker=uxTextField(html:type=time)</code></td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__1\">Supported triggers:</td>\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\"><code class=\"ph codeph\">onchange</code></td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__1\">Use for:</td>\n<td class=\"entry\" headers=\"ybq1777462965352__table_jjs_tks_q1c__entry__2\">Fields of Uniface data types Date, Time, and\n\t\t\t\t\t\t\t\t\tDateTime.</td>\n</tr>\n</tbody></table></div>\n</div>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_29422583\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true