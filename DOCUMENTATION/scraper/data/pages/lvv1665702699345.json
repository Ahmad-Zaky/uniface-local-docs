opicActionsMobile\" data-target=\"#feedbackModal_main_2529758\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Aug 23, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104lvv1665702699345.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/lvv1665702699345.html\" id=\"bundle:uniface_104/enus/lvv1665702699345.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"lvv1665702699345\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n                       \n ProcScript for Disconnected Record Sets \n   </h1>\n<div class=\"body refbody\"><p class=\"shortdesc\">Uniface supports XML, JSON, and Uniface Structs for disconnected record sets and provides specialized ProcScript instructions for saving, loading, reconnecting and querying data from disconnected record sets.\n </p>\n<section class=\"section\" id=\"lvv1665702699345__section_w4352ab1b5b1_w4353ab1b5_w4354ab1\">\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1\"><caption><span class=\"table--title-label\">Table 1. </span><span class=\"title\">ProcScript for Disconnected Record Sets</span></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n Command\n </th>\n<th class=\"entry\" dir=\"ltr\" id=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Purpose\n </th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"ebq1665702566280.html\" href=\"/de-DE/bundle/uniface_104/page/ebq1665702566280.html\" title=\"Places component data in an XML stream.\">xmlsave</a> and <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"vuu1665702574732.html\" href=\"/de-DE/bundle/uniface_104/page/vuu1665702574732.html\" title=\"Load data from an XML stream into occurrences drawn on the component.\">xmlload</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Save data as XML to a disconnected data set, and load it into a component.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"idq1665702567079.html\" href=\"/de-DE/bundle/uniface_104/page/idq1665702567079.html\" title='Writes a JSON stream from the data in a component to $webinfo(\"data\").'>websave</a> and <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"fyg1714374176100.html\" href=\"/de-DE/bundle/uniface_104/page/fyg1714374176100.html\" title='Loads data from a JSON stream in $webinfo(\"data\") into a component.'>webload</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Save data as JSON to a disconnected data set, and load it into a component.\n <div class=\"note note note_note\" id=\"lvv1665702699345__note_w4355ab1b5b1b1b3b7b3b3b1_w4356ab1b5b1b1b3b7b3b3_w4357ab1b5b1b1b3b7b3_w4358ab1b5b1b1b3b7_w4359ab1b5b1b1b3_w4360ab1b5b1b1_w4361ab1b5b1_w4362ab1b5_w4363ab1\"><span class=\"note__title\">Note:</span> Uniface uses these commands in DSPs to pass data to and from the browser.</div>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"efi1719389270623.html\" href=\"/de-DE/bundle/uniface_104/page/efi1719389270623.html\" title=\"Writes component data to a Struct.\">componentToStruct</a> and <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"lln1665702574971.html\" href=\"/de-DE/bundle/uniface_104/page/lln1665702574971.html\" title=\"Converts data from a Struct or collection of Structs into the entities and occurrences in the component.\">structToComponent</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Save data as a Struct to a disconnected data set, and load it into a component.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qnx1665702574893.html\" href=\"/de-DE/bundle/uniface_104/page/qnx1665702574893.html\" title=\"Reconnect data loaded from a disconnected record set (XML, JSON, or Struct) with the occurrences in a component and database (if connected).\">reconnect</a> or <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"thr1665702690548.html\" href=\"/de-DE/bundle/uniface_104/page/thr1665702690548.html\" title=\"Reconnect data loaded from a disconnected record set (XML, JSON, or Struct) with the occurrences in a database or component.\">retrieve/reconnect</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Reconnect data that has been loaded from a disconnected record set with the data already in the component and the database, if connected.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"vrt1665702699416.html\" href=\"/de-DE/bundle/uniface_104/page/vrt1665702699416.html\" title=\"Returns the modification status for each disconnected occurrence in a component.\">$occstatus</a>\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"qis1665702699490.html\" href=\"/de-DE/bundle/uniface_104/page/qis1665702699490.html\" title=\"Set or return the CRC checksum of an occurrence.\">$occcrc</a>\n</p>\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"owr1665702661127.html\" href=\"/de-DE/bundle/uniface_104/page/owr1665702661127.html\" title=\"Returns the removal status of an occurrence.\">$occdel</a>\n</p>\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"eai1665702600334.html\" href=\"/de-DE/bundle/uniface_104/page/eai1665702600334.html\" title=\"Return the modification status of an occurrence.\">$occmod</a>\n</p>\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"aqg1665702684263.html\" href=\"/de-DE/bundle/uniface_104/page/aqg1665702684263.html\" title=\"Returns or sets the properties of an occurrence.\">$occproperties</a>\n</p>\n<p class=\"p\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"znp1665702699570.html\" href=\"/de-DE/bundle/uniface_104/page/znp1665702699570.html\" title=\"Return the type of update for the current occurrence.\">$storetype</a>\n</p>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"lvv1665702699345__table_d4241e1_d4242e1_d4243e1__entry__2\">\n Get (or set) the values of reconnect properties\n </td>\n</tr>\n</tbody></table></div>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529758\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2529758\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "ProcScript for Disconnected Record Sets Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Aug 23, 2024 Summarize Uniface 10.4 ProcScript for Disconnected Record Sets Uniface supports XML, JSON, and Uniface Structs for disconnected record sets and provides specialized ProcScript instructions for saving, loading, reconnecting and querying data from disconnected record sets. Table 1. ProcScript for Disconnected Record Sets Command Purpose xmlsave and xmlload Save data as XML to a disconnected data set, and load it into a component. websave and webload Save data as JSON to a disconnected data set, and load it into a component. Note: Uniface uses these commands in DSPs to pass data to and from the browser. componentToStruct and structToComponent Save data as a Struct to a disconnected data set, and load it into a component. reconnect or retrieve/reconnect Reconnect data that has been loaded from a disconnected record set with the data already in the component and the database, if connected. $occstatus $occcrc $occdel $occmod $occproperties $storetype Get (or set) the values of reconnect properties Was this topic helpful? Like Dislike"}