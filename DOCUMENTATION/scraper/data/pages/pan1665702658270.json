tr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 023\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Logical OR.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" colspan=\"4\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">\n                        Context-dependent 1profile characters: \n                     </p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n *\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 016\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Asterisk, or 0 through <var class=\"keyword varname\">n</var> characters.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n ?\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 017\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Question mark, or any single character.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n =\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 018\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Equals sign, or equals.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n &gt;\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 019\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Greater than sign, or greater than.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n &lt;\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 020\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Less than sign, or less than.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n !\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 021\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Exclamation point, or logical NOT.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n &amp;\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 022\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Ampersand, or logical AND.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n |\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 1\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 023\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Vertical bar, or logical OR.</p>\n</td>\n</tr>\n</tbody></table></div>\n<section class=\"section\" id=\"pan1665702658270__topic_d41687e1_d41688e1_d41689e1_d41690e1_d41691e1\"><h2 class=\"title sectiontitle\" id=\"d1002806e458\">\n                       \n GOLD Character\n </h2>\n<p class=\"p\" id=\"pan1665702658270__p_d63224e1_d63225e1_d63226e1\">The GOLD character is an escape character that, by default, is displayed as a middle-dot Uniface special character.</p>\n<p class=\"p\" id=\"pan1665702658270__p_d63227e1_d63228e1_d63229e1\">When a profile character, such as GOLD *, is stored in\n            a field, the field will contain the GOLD character followed by an asterisk\n               (<code class=\"ph codeph\">*</code>). In a Unifield, the profile character GOLD * is displayed as a\n            highlighted asterisk. In an edit box, it is displayed as a middle-dot followed by a\n            asterisk.</p>\n<p class=\"p\" id=\"pan1665702658270__p_d63230e1_d63231e1_d63232e1\">The same applies for the middle-dot character itself. In a Unifield, the character is displayed as a middle-dot character, but in an edit box as two middle-dots; one for specifying the escape character and another for the middle-dot character itself. When the middle-dot character is saved into a field of a database, the character is stored as one middle-dot character.</p>\n<p class=\"p\" id=\"pan1665702658270__p_d63233e1_d63234e1_d63235e1\">To type the middle-dot character, you must type it twice, otherwise the character will disappear when the field or Code Editor is refreshed. Uniface will process the twice-typed middle-dot as one character. The same applies for entering the middle-dot character in an edit box.</p>\n<p class=\"p\" id=\"pan1665702658270__p_d63236e1_d63237e1_d63238e1\">On Windows, you\n            can change the prefix character used when displaying profile characters in widgets using\n            the <span class=\"keyword cmdname\">PROFILE</span> initialization setting. For more information, see <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"jav1665702616964.html\" href=\"/de-DE/bundle/uniface_104/page/jav1665702616964.html\" title=\"Determines the prefix character used when displaying profile characters in widgets (but not Unifields).\">Profile</a>.</p>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2530842\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2530842\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Subfield Separator and Profile Characters Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 07, 2024 Summarize Uniface 10.4 Subfield Separator and Profile Characters Uniface uses part of the reserved area of each meta character set (that is, the first 32 characters plus the last character) to store characters with special meaning within Uniface, such as subfield separators and profile characters. Subfield separators are used in lists and subfields to separate list items and sub-fields. Profile characters are used as wildcards in fields to retrieve records that match the search profile. Context-dependent profile characters may be treated as profile characters, depending on the context. Literal characters corresponding to profile characters are part of the Font 0 character set. Table 1. Uniface Special Characters Character Font Decimal Meaning Subfield separator: GOLD ; 0 027 Subfield separator. Profile characters: GOLD * 0 016 0 through n characters. GOLD ? 0 017 Any single character. GOLD = 0 018 Equals. GOLD > 0 019 Greater than. GOLD < 0 020 Less than. GOLD ! 0 021 Logical NOT. GOLD & 0 022 Logical AND. GOLD | 0 023 Logical OR. Context-dependent 1profile characters: * 1 016 Asterisk, or 0 through n characters. ? 1 017 Question mark, or any single character. = 1 018 Equals sign, or equals. > 1 019 Greater than sign, or greater than. < 1 020 Less than sign, or less than. ! 1 021 Exclamation point, or logical NOT. & 1 022 Ampersand, or logical AND. | 1 023 Vertical bar, or logical OR. GOLD Character The GOLD character is an escape character that, by default, is displayed as a middle-dot Uniface special character. When a profile character, such as GOLD *, is stored in a field, the field will contain the GOLD character followed by an asterisk ( * ). In a Unifield, the profile character GOLD * is displayed as a highlighted asterisk. In an edit box, it is displayed as a middle-dot followed by a asterisk. The same applies for the middle-dot character itself. In a Unifield, the character is displayed as a middle-dot character, but in an edit box as two middle-dots; one for specifying the escape character and another for the middle-dot character itself. When the middle-dot character is saved into a field of a database, the character is stored as one middle-dot character. To type the middle-dot character, you must type it twice, otherwise the character will disappear when the field or Code Editor is refreshed. Uniface will process the twice-typed middle-dot as one character. The same applies for entering the middle-dot character in an edit box. On Windows, you can change the prefix character used when displaying profile characters in widgets using the PROFILE initialization setting. For more information, see Profile . Was this topic helpful? Like Dislike"}