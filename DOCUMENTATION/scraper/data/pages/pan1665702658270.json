odal_main_2530842\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Okt 07, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104pan1665702658270.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/pan1665702658270.html\" id=\"bundle:uniface_104/enus/pan1665702658270.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"pan1665702658270\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n                     \n Subfield Separator and Profile Characters\n   </h1>\n<div class=\"body conbody\" id=\"pan1665702658270__subfield_separator_and_profile_characters_188933\"><p class=\"shortdesc\">Uniface uses part of the reserved area of each meta character set (that is, the first 32 characters plus the last character) to store characters with special meaning within Uniface, such as subfield separators and profile characters.\n </p>\n<ul class=\"ul\">\n<li class=\"li\" id=\"pan1665702658270__li_d27551e1_d27552e1_d27553e1\">Subfield separators are used in lists and subfields to separate list items and sub-fields.\n </li>\n<li class=\"li\" id=\"pan1665702658270__li_d27554e1_d27555e1_d27556e1\">Profile characters are used as wildcards in fields\n            to retrieve records that match the search profile. </li>\n<li class=\"li\" id=\"pan1665702658270__li_d27557e1_d27558e1_d27559e1\">Context-dependent profile characters may be treated as profile characters, depending on the context.\n </li>\n</ul>\n<p class=\"p\" id=\"pan1665702658270__p_d63218e1_d63219e1_d63220e1\">Literal characters corresponding to profile characters are part of the Font 0 character set.</p>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"4\" id=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1\"><caption><span class=\"table--title-label\">Table 1. </span><span class=\"title\">Uniface Special Characters</span></caption><colgroup><col/><col/><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n<p class=\"p\">Character</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n<p class=\"p\">Font</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n<p class=\"p\">Decimal</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Meaning</p>\n</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" colspan=\"4\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">\n                        Subfield separator: \n                     </p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n GOLD ;\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 027\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n Subfield separator.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" colspan=\"4\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3 pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">\n                        Profile characters: \n                     </p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n GOLD *\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 016\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">0 through <var class=\"keyword varname\">n</var> characters.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n GOLD ?\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 017\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Any single character.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n GOLD =\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__3\">\n 018\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__4\">\n<p class=\"p\">Equals.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__1\">\n GOLD &gt;\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d5537e1_d5538e1_d5539e1__entry__2\">\n 0\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"pan1665702658270__table_d55