w: hidden;\">Description</div></th><th aria-controls=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1\" aria-label=\"Platform: activate to sort column ascending\" class=\"entry sorting\" colspan=\"1\" dir=\"ltr\" id=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__3\" rowspan=\"1\" style=\"padding-top: 0px; padding-bottom: 0px; border-top-width: 0px; border-bottom-width: 0px; height: 0px; width: 100.656px;\"><div class=\"dataTables_sizing\" style=\"height: 0px; overflow: hidden;\">Platform</div></th></tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__1\">CP1250</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__2\">Code page 1250 for Eastern European\n\t\t\t\t language</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__3\">Windows</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__1\">CP1251</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__2\"> Code page 1251 for Cyrillic language</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__3\">Windows</td>\n</tr><tr class=\"row odd\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__1\">CP1252</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__2\">Code page 1252 for Western European\n\t\t\t\t language</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d16609e1__entry__3\">Windows</td>\n</tr><tr class=\"row even\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"azs1665703222737__table_d16607e1_d16608e1_d1