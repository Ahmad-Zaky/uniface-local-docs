{"id": "luh1665702748423", "title": "Uninstalling Sentinel RMS License Manager on Unix", "breadcrumbs": ["Uniface License Management", "Sentinel RMS License Manager", "Installing the Sentinel RMS License Manager on Unix and Linux", "Uninstalling Sentinel RMS License Manager on Unix"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/luh1665702748423.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Uninstalling Sentinel RMS License Manager on Unix</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:  Updating the Sentinel RMS License Manager on Unix and Linux \" class=\"\" data-tooltip-content=\"Previous:  Updating the Sentinel RMS License Manager on Unix and Linux \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/mjb1665702748492.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next: Starting and Stopping the Sentinel RMS License Manager on Unix and Linux \" class=\"\" data-tooltip-content=\"Next: Starting and Stopping the Sentinel RMS License Manager on Unix and Linux \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/qhf1665702748352.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" t