opicActionsMobile\" data-target=\"#feedbackModal_main_3614929\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Okt 11, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104nzs1665702641037.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/nzs1665702641037.html\" id=\"bundle:uniface_104/enus/nzs1665702641037.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"nzs1665702641037\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Tab Space (TabSpace)\n </h1>\n<div class=\"body conbody\"><p class=\"shortdesc\">Size of the space to be displayed between tabs, in either pixels or character cells.\n </p>\n<p class=\"p\" id=\"nzs1665702641037__p_d107765e1_d107766e1_d107767e1\"><code class=\"ph codeph\">\"</code>TabSpace<code class=\"ph codeph\">=</code><var class=\"keyword varname\">Cells</var> |\n            <var class=\"keyword varname\">Pixels</var><code class=\"ph codeph\">px</code><code class=\"ph codeph\">\"</code></p>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1\"><caption></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__1\">\n Value\n </th>\n<th class=\"entry\" dir=\"ltr\" id=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__2\">\n Description\n </th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__1\"><code class=\"ph codeph defvalue\">0</code></td>\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__2\">\n No space between tabs\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__1\"><var class=\"keyword varname\">Cells</var></td>\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__2\">\n Space size as number of character cells.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__1\"><var class=\"keyword varname\">Pixels</var><code class=\"ph codeph\">px</code></td>\n<td class=\"entry\" dir=\"ltr\" headers=\"nzs1665702641037__table_d12698e1_d12699e1_d12700e1__entry__2\">\n Space size as number of pixels.\n </td>\n</tr>\n</tbody></table></div>\n<section class=\"section\" id=\"nzs1665702641037__section_oj3_bd1_1xb\"><h2 class=\"title sectiontitle\" id=\"d479082e124\">Usage</h2>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"nzs1665702641037__table_d12701e1_d12702e1_d12703e1\"><caption></caption><colgroup><col/><col/></colgroup><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\"> Dynamic? </td>\n<td class=\"entry\" dir=\"ltr\"> Yes </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\"> Supported in Grid? </td>\n<td class=\"entry\" dir=\"ltr\"> No </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\"> Dependencies: </td>\n<td class=\"entry\" dir=\"ltr\"></td>\n</tr>\n</tbody></table></div>\n</section>\n<section class=\"section\" id=\"nzs1665702641037__section_hqw_dd1_1xb\"><h2 class=\"title sectiontitle\" id=\"d479082e169\">Using in ProcScript</h2>\n<p class=\"p\" id=\"nzs1665702641037__p_d107774e1_d107775e1_d107776e1\">You can use <span class=\"keyword cmdname\">$properties</span> or\n               <span class=\"keyword cmdname\">$fieldproperties</span> to set or get the property and its value. For\n            more information, see <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"zie1665702558978.html\" href=\"/de-DE/bundle/uniface_104/page/zie1665702558978.html\" title=\"Return or set the current widget properties of a field.\">$properties</a> and <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"aud1705998763272.html\" href=\"/de-DE/bundle/uniface_104/page/aud1705998763272.html\" title=\"Return or set the current widget properties of an instance of a field.\">$fieldproperties</a>.</p>\n<div class=\"code-toolbar\"><pre class=\"pre language-plaintext\" id=\"nzs1665702641037__pre_tq2_fd1_1xb\" tabindex=\"0\"><code class=\"language-plaintext\">$fieldproperties(FLD) = \"tabspace=5px\"</code></pre><div class=\"toolbar\"><div class=\"toolbar-item\"><button class=\"copy-to-clipboard-button\" data-copy-state=\"copy\" type=\"button\"><span>Copy</span></button></div></div></div>\n</section>\n<section class=\"section\" id=\"nzs1665702641037__section_ty3_fd1_1xb\"><h2 class=\"title sectiontitle\" id=\"d479082e201\">Example: Tab Space in Pixels</h2>\n<p class=\"p\" id=\"nzs1665702641037__p_d107780e1_d107781e1_d107782e1\">\n<span class=\"ph uicontrol\">Tab Space</span> is set to <code class=\"ph codeph\">5px</code>:</p>\n<figure class=\"fig fignone\" id=\"nzs1665702641037__fig_d107783e1_d107784e1_d107785e1\"><figcaption><span class=\"fig--title-label\">Figure 1. </span>Tab Space of 5 Pixels</figcaption>\n<img alt=\"Image\" class=\"image\" id=\"nzs1665702641037__image_o1f_jd1_1xb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/tabpace.png?_LANG=enus\"/>\n</figure>\n</section>\n<section class=\"section\" id=\"nzs1665702641037__section_xvt_jd1_1xb\"><h2 class=\"title sectiontitle\" id=\"d479082e229\">Example: Tab Space in Character Cells</h2>\n<p class=\"p\" id=\"nzs1665702641037__p_d107792e1_d107793e1_d107794e1\">\n<span class=\"ph uicontrol\">Tab Space</span> is set to <code class=\"ph codeph\">1</code>:</p>\n<figure class=\"fig fignone\" id=\"nzs1665702641037__fig_d107795e1_d107796e1_d107797e1\"><figcaption><span class=\"fig--title-label\">Figure 2. </span>Tab Space of One Character Cell</figcaption>\n<img alt=\"Image\" class=\"image\" id=\"nzs1665702641037__image_kz3_md1_1xb\" src=\"https://docs-be.rocketsoftware.com/bundle/uniface_104/page/tabspace_char.png?_LANG=enus\"/>\n</figure>\n</section>\n<section class=\"section\" id=\"nzs1665702641037__section_ucd_nd1_1xb\"><h2 class=\"title sectiontitle\" id=\"d479082e256\">Applies To</h2>\n<p class=\"p\"><a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"gyf1688451219719.html\" href=\"/de-DE/bundle/uniface_104/page/gyf1688451219719.html\" title=\"The utabex widget enables users to navigate through a collection of contained forms by clicking a tab to display the form. The utabex widget is highly customizable, allowing extensive control over the appearance and behavior of the tabs. Uniface provides a logical widget called TabEx, which is mapped to utabex.\">utabex (TabEx)</a></p>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3614929\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_3614929\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Tab Space (TabSpace) Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Okt 11, 2024 Summarize Uniface 10.4 Tab Space (TabSpace) Size of the space to be displayed between tabs, in either pixels or character cells. \" TabSpace = Cells | Pixels px \" Value Description 0 No space between tabs Cells Space size as number of character cells. Pixels px Space size as number of pixels. Usage Dynamic? Yes Supported in Grid? No Dependencies: Using in ProcScript You can use $properties or $fieldproperties to set or get the property and its value. For more information, see $properties and $fieldproperties . $fieldproperties(FLD) = \"tabspace=5px\" Copy Example: Tab Space in Pixels Tab Space is set to 5px : Figure 1. Tab Space of 5 Pixels Example: Tab Space in Character Cells Tab Space is set to 1 : Figure 2. Tab Space of One Character Cell Applies To utabex (TabEx) Was this topic helpful? Like Dislike"}