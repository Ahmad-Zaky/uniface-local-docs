g-none d-flex zDocsFeedbackButton\" data-backdrop=\"static\" data-return-focus=\"#zDocsTopicActionsMobile\" data-target=\"#feedbackModal_main_2528658\" data-toggle=\"modal\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-feedback\"><use xlink:href=\"#ico-feedback\"></use></svg><span class=\"zDocsFeedbackButtonText\"> Feedback</span></span></div></div><div class=\"zDocsTopicActionsMobile\"><button aria-label=\"Show topic actions\" data-toggle=\"dropdown\" id=\"zDocsTopicActionsMobile\"><svg aria-hidden=\"true\" class=\"ico-ellipsis-h\"><use xlink:href=\"#ico-ellipsis-h\"></use></svg></button><div class=\"dropdown-menu zDocsDropdownMenu zDocsTopicActionsMobileDropdown dropdown-menu-right\"></div></div><div style=\"flex-basis: 100%; height: 0px;\"></div><ul class=\"zDocsTopicPageDetails\"><li class=\"zDocsTopicPageDate css-cinqea\">Last Updated<span class=\"css-cinqea\">Sept 10, 2024</span></li><li class=\"zDocsAiTopicSummaryDetailsItem\"><button class=\"zDocsAiTopicSummaryButton\"><svg aria-hidden=\"true\" class=\"ico-topic-summary\"><use xlink:href=\"#ico-topic-summary\"></use></svg>Summarize</button></li><li class=\"spacer\" role=\"presentation\"></li><div class=\"zDocsLabelWrapper\"><ul><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: Uniface\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=prod_uniface\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>Uniface</a></li><li class=\"zDocsLabel\"><a aria-describedby=\"hyperLinkFacetsTooltip\" class=\"css-ettsdk\" data-tooltip-content=\"Search all site by tag: 10.4\" data-tooltip-id=\"hyperLinkFacetsTooltip\" href=\"/de-DE/search?labelkey=uniface_10.4\" stylesprops=\"[object Object]\"><svg aria-label=\"Tag\" class=\"ico-tag\" role=\"img\"><use xlink:href=\"#ico-tag\"></use></svg>10.4</a></li></ul></div></ul></header><div class=\"zDocsTopicPageBody\" data-prismjs-copy=\"Copy\" data-prismjs-copy-error=\"Copy failed! Use Ctrl + C instead.\" data-prismjs-copy-success=\"Copied!\"><div class=\"zDocsTopicPageBodyContent wide\" dir=\"ltr\"><div id=\"zDocsAiSummaryContaineruniface_104iqm1665702876023.html\"></div><div><article class=\"hascomments\" data-page=\"bundle:uniface_104/enus/iqm1665702876023.html\" id=\"bundle:uniface_104/enus/iqm1665702876023.html\"><main role=\"main\"><article aria-labelledby=\"ariaid-title1\" class=\"dita\" id=\"iqm1665702876023\" role=\"article\">\n<h1 class=\"title topictitle1\" id=\"ariaid-title1\">\n      Settings for Specific Character Sets\n </h1>\n<div class=\"body refbody\"><p class=\"shortdesc\">You can specify the layout orientation of the application. This is important for the bidirectional character sets such as Arabic and Hebrew. To use Japanese Gaiji characters, use <span class=\"keyword cmdname\">$GAIJI</span> setting. Use <span class=\"keyword cmdname\">$NLS_SORT_ORDER</span> to select the sorting order for a double-byte character set.\n </p>\n<section class=\"section\" id=\"iqm1665702876023__section_w8551ab1b5b1_w8552ab1b5_w8553ab1\">\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"2\" id=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1\"><caption><span class=\"table--title-label\">Table 1. </span><span class=\"title\">Assignment Settings for RTL Character Sets</span></caption><colgroup><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__1\">\n Setting\n </th>\n<th class=\"entry\" dir=\"ltr\" id=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__2\">\n Description\n </th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"rtm1665702721231.html\" href=\"/de-DE/bundle/uniface_104/page/rtm1665702721231.html\" title=\"Specify that the desktop application will read from right to left instead of from left to right. This causes the layout of all forms and their contents to be mirrored, so that the starting point for reading is the right side.\">$RTL_APPLICATION</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__2\">\n Specify the layout orientation of forms and menus during deployment.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"nvi1665702721301.html\" href=\"/de-DE/bundle/uniface_104/page/nvi1665702721301.html\" title=\"Set the position of the cursor in the field at deployment. For right-to-left applications only.\">$RTL_FIELDS</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__2\">\n Specify the layout orientation of fields during deployment.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"dvt1665702627513.html\" href=\"/de-DE/bundle/uniface_104/page/dvt1665702627513.html\" title=\"Replace all unifields with edit boxes.\">$NO_UNIFIELDS</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__2\">Replace Unifield by an edit box because\n                           <span class=\"keyword cmdname\">$rtl_field</span>=<code class=\"ph codeph\">on</code> cannot be applied to a\n                        Unifield. </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"gns1665702606915.html\" href=\"/de-DE/bundle/uniface_104/page/gns1665702606915.html\" title=\"Determine processing required when printing right-to-left fields.\">$RTL_PRINTING</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2972e1_d2973e1_d2974e1__entry__2\">\n If the printer cannot handle right-to-left printing, use <span class=\"keyword cmdname\">$rtl_printing</span>.\n </td>\n</tr>\n</tbody></table></div>\n<div class=\"table-wrap\"><table class=\"table\" count-columns=\"3\" id=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1\"><caption><span class=\"table--title-label\">Table 2. </span><span class=\"title\">Settings for Double-Byte Character Sets</span></caption><colgroup><col/><col/><col/></colgroup><thead class=\"thead\">\n<tr class=\"row\" dir=\"ltr\">\n<th class=\"entry\" dir=\"ltr\" id=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__1\">\n<p class=\"p\">Setting</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__2\">\n<p class=\"p\">Type</p>\n</th>\n<th class=\"entry\" dir=\"ltr\" id=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__3\">\n<p class=\"p\">Description</p>\n</th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"guj1665702720735.html\" href=\"/de-DE/bundle/uniface_104/page/guj1665702720735.html\" title=\"Allow the use of Japanese Gaiji characters.\">$GAIJI</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__2\">\n Assignment\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__3\">Set <span class=\"keyword cmdname\">$GAIJI</span> to True to enable\n                        Gaiji characters. The Uniface 8 setting <span class=\"keyword cmdname\">$DOUBLE_WIDTH</span> =\n                           <code class=\"ph codeph\">8</code> is equivalent to the Uniface 9 setting\n                           <span class=\"keyword cmdname\">$GAIJI</span> = True. </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bdr1665702552884.html\" href=\"/de-DE/bundle/uniface_104/page/bdr1665702552884.html\" title=\"Specify the default sequencing rules used when sorting strings, or reading string data from the database with the order by clause.\">$NLS_SORT_ORDER</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__2\">\n Assignment\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__3\">\n Determine how the ProcScript statement <span class=\"keyword cmdname\">sort</span> and <span class=\"keyword cmdname\">sort/list</span> order data during sorting.\n </td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"pvy1665702614635.html\" href=\"/de-DE/bundle/uniface_104/page/pvy1665702614635.html\" title=\"Enable the Input Method Editor (IME) for string fields for which the input mode has not been explicitly defined (by the field syntax YIME (IME on) or NIME (IME off)).\">AutoImeOpen</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__2\">\n Initialization\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__3\">\n If <span class=\"keyword cmdname\">AUTOIMEOPEN</span> is on, the IME is switched to the language-specific input mode, for example Hiragana, when the focus moves to a string field.\n <p class=\"p\">To select an Input Method mode for an individual string field, use field syntax <code class=\"ph codeph\">YIME</code> or <code class=\"ph codeph\">NIME</code>. See <a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"zlt1665702557043.html\" href=\"/de-DE/bundle/uniface_104/page/zlt1665702557043.html\" title=\"The Field Syntax property specifies the input format for data, including the entry format (for example, 1-Dec-14 or 20141201), the allowed characters, and whether the field is mandatory or read-only.\">Field Syntax</a>.</p>\n</td>\n</tr>\n<tr class=\"row\" dir=\"ltr\">\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__1\">\n<a class=\"xref\" data-bundleid=\"uniface_104\" data-navpath=\"bsu1665702614517.html\" href=\"/de-DE/bundle/uniface_104/page/bsu1665702614517.html\" title=\"Controls whether the language-specific input mode in the Input Method Editor (IME) is disabled when the GOLD key is used.\">AutoImeGold</a>\n</td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__2\">\n Initialization\n </td>\n<td class=\"entry\" dir=\"ltr\" headers=\"iqm1665702876023__table_d2975e1_d2976e1_d2977e1__entry__3\">\n If <span class=\"keyword cmdname\">AUTOIMEGOLD</span> is on, the IME is switched to direct input mode when the GOLD key is used. Once the complete GOLD key sequence has been entered, the IME is returned to its previous state.\n </td>\n</tr>\n</tbody></table></div>\n</section>\n</div>\n</article></main></article>\n</div></div></div><div class=\"bottomFeedback\"><div aria-labelledby=\"bottomFeedbackText\" class=\"bottomFeedbackContent\" role=\"group\"><span class=\"bottomFeedbackText\" id=\"bottomFeedbackText\">Was this topic helpful?</span><div class=\"bottomFeedbackButtonGroup\"><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2528658\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-up\"><use xlink:href=\"#ico-thumbs-up\"></use></svg><span>Like</span></a><a data-backdrop=\"static\" data-target=\"#feedbackModal_bottom_2528658\" data-toggle=\"modal\" href=\"#\" role=\"button\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-thumbs-down\"><use xlink:href=\"#ico-thumbs-down\"></use></svg><span>Dislike</span></a></div></div></div><div style=\"position: fixed; bottom: 170px; right: 70px; cursor: pointer; transition-duration: 0.2s; transition-timing-function: linear; transition-delay: 0s; z-index: 3; opacity: 0; visibility: hidden; transition-property: opacity, visibility;\"><button aria-label=\"Scroll to top\" class=\"zDocsScrollTopBtn\" data-tooltip-content=\"Scroll to top\" data-tooltip-id=\"zDocsBackToTopToolTip\" id=\"zDocsScrollToTop\" type=\"button\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></button></div></body></html>", "text": "Settings for Specific Character Sets Add to My Topics Add selected topic and subtopics Add Topic & Subtopics with topic head Add entire publication Watch Download PDF Save selected topic Save selected topic and subtopics Save entire publication Share Email Link Copy Link Feedback Last Updated Sept 10, 2024 Summarize Uniface 10.4 Settings for Specific Character Sets You can specify the layout orientation of the application. This is important for the bidirectional character sets such as Arabic and Hebrew. To use Japanese Gaiji characters, use $GAIJI setting. Use $NLS_SORT_ORDER to select the sorting order for a double-byte character set. Table 1. Assignment Settings for RTL Character Sets Setting Description $RTL_APPLICATION Specify the layout orientation of forms and menus during deployment. $RTL_FIELDS Specify the layout orientation of fields during deployment. $NO_UNIFIELDS Replace Unifield by an edit box because $rtl_field = on cannot be applied to a Unifield. $RTL_PRINTING If the printer cannot handle right-to-left printing, use $rtl_printing . Table 2. Settings for Double-Byte Character Sets Setting Type Description $GAIJI Assignment Set $GAIJI to True to enable Gaiji characters. The Uniface 8 setting $DOUBLE_WIDTH = 8 is equivalent to the Uniface 9 setting $GAIJI = True. $NLS_SORT_ORDER Assignment Determine how the ProcScript statement sort and sort/list order data during sorting. AutoImeOpen Initialization If AUTOIMEOPEN is on, the IME is switched to the language-specific input mode, for example Hiragana, when the focus moves to a string field. To select an Input Method mode for an individual string field, use field syntax YIME or NIME . See Field Syntax . AutoImeGold Initialization If AUTOIMEGOLD is on, the IME is switched to direct input mode when the GOLD key is used. Once the complete GOLD key sequence has been entered, the IME is returned to its previous state. Was this topic helpful? Like Dislike"}