dy\">\n<tr class=\"row odd\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Widget node</td>\n</tr><tr class=\"row even\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select.open</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Widget node when the listbox is opened or expanded</td>\n</tr><tr class=\"row odd\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select .u-error-icon</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Error icon node</td>\n</tr><tr class=\"row even\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select.disabled</code> or\n\t\t\t\t\t\t\t\t\t\t.<code class=\"ph codeph\">u-select[disabled]</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Widget node when the widget is disabled</td>\n</tr><tr class=\"row odd\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select.u-invalid</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Widget node when the value is invalid</td>\n</tr><tr class=\"row even\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select.u-format-invalid</code></td>\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__2\">Widget node when there is a format invalid</td>\n</tr><tr class=\"row odd\">\n<td class=\"entry\" headers=\"yzp1709198831196__table_xsc_ljl_q1c__entry__1\"><code class=\"ph codeph\">.u-select::part(selected-value)</code></td>\n<td class=\"entry\" headers=\"yzp170919883119