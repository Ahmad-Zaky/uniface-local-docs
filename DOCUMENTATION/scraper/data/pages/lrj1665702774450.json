{"id": "lrj1665702774450", "title": "Uniface 10.4.01: Currency Updates Since 10.3.02", "breadcrumbs": ["Rocket Uniface Library 10.4", "Uniface 10: Changes per Release", "What's New in Uniface 10.4.01", "Uniface 10.4.01: Currency Updates Since 10.3.02"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/lrj1665702774450.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Uniface 10.4.01: Currency Updates Since 10.3.02</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:  Uniface 10.4.01: New Features Since 10.3.02 \" class=\"\" data-tooltip-content=\"Previous:  Uniface 10.4.01: New Features Since 10.3.02 \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/urf1665702772780.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next:  Uniface 10.4.01: Issues Fixed Since 10.3.02 \" class=\"\" data-tooltip-content=\"Next:  Uniface 10.4.01: Issues Fixed Since 10.3.02 \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/vfl1665702774984.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></spa