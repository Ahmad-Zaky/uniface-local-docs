{"id": "jyy1705583151243", "title": "Working with Panels", "breadcrumbs": ["Constructing Components and Other Objects", "Application Shells", "Libraries of Runtime Objects", "Panels", "Working with Panels"], "url": "https://docs.rocketsoftware.com/de-DE/bundle/uniface_104/page/jyy1705583151243.html", "html": "<html><body><header class=\"zDocsTopicPageHead\"><h1 class=\"css-g931ng\">Working with Panels</h1><div class=\"zDocsTopicActions\" role=\"list\"><div class=\"zDocsBundlePagination\" data-testid=\"next-prev-container\" role=\"listitem\"><div class=\"zDocsPrevTopicButton zDocsPrevTopicButton\"><span class=\"\"><a aria-label=\"Previous:   Panels \" class=\"\" data-tooltip-content=\"Previous:   Panels \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/byf1705583062647.html\"><svg aria-hidden=\"true\" class=\"ico-prev\"><use xlink:href=\"#ico-prev\"></use></svg></a></span></div><div class=\"zDocsNextTopicButton zDocsNextTopicButton\"><span class=\"\"><a aria-label=\"Next: Drag-and-Drop Formats  \" class=\"\" data-tooltip-content=\"Next: Drag-and-Drop Formats  \" data-tooltip-id=\"zDocsTopicActionsTooltip\" data-tooltip-open=\"false\" href=\"/de-DE/bundle/uniface_104/page/xzb1705583342348.html\"><svg aria-hidden=\"true\" class=\"ico-next\"><use xlink:href=\"#ico-next\"></use></svg></a></span></div></div><div class=\"zDocsMyDocsMenu\" role=\"listitem\"><span aria-expanded=\"false\" aria-label=\"Add to My Topics\" class=\"d-none d-lg-flex\" data-toggle=\"dropdown\" data-tooltip-content=\"Add to My Topics\" data-tooltip-id=\"zDocsTopicActionsTooltip\" id=\"addToMyDocsDropdownTrigger\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg></span><span class=\"d-lg-none d-flex\" role=\"button\" tabindex=\"0\"><svg aria-hidden=\"true\" class=\"ico-bookmark-add\"><use xlink:href=\"#ico-bookmark-add\"></use></svg>Add to My Topics</spa